@@ -0,0 +1,42 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+BUNDLE_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
+TOOLS_DIR="$BUNDLE_ROOT/tools/linux"
+CHECKPATCH_WRAPPER="$SCRIPT_DIR/checkpatch-driver"
+
+if [[ $# -eq 0 ]]; then
+	cat >&2 <<'USAGE'
+Usage: lint-c <file.c|file.h> [...]
+
+Runs:
+  1) checkpatch-driver -f <file>
+  2) checkincludes.pl <file>
+  3) checkdeclares.pl <file> (headers only)
+USAGE
+	exit 1
+fi
+
+status=0
+
+for file in "$@"; do
+	echo "[lint-c] checkpatch: $file"
+	if ! "$CHECKPATCH_WRAPPER" -f "$file"; then
+		status=1
+	fi
+
+	echo "[lint-c] checkincludes: $file"
+	if ! perl "$TOOLS_DIR/checkincludes.pl" "$file"; then
+		status=1
+	fi
+
+	if [[ "$file" == *.h ]]; then
+		echo "[lint-c] checkdeclares: $file"
+		if ! perl "$TOOLS_DIR/checkdeclares.pl" "$file"; then
+			status=1
+		fi
+	fi
+done
+
+exit "$status"
