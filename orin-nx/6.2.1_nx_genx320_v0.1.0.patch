+
+#ifndef __GENX320_I2C_TABLES__
+#define __GENX320_I2C_TABLES__
+
+#include <media/camera_common.h>
+
+#include "genx320_regs.h"
+
+#define GENX320_TABLE_WAIT_MS 0xFFFE
+#define GENX320_TABLE_WAIT_ROI_MASTER 0xFFFD
+#define GENX320_TABLE_END 0xFFFF
+
+#define GENX320_WAIT_MS_STOP 1
+#define GENX320_WAIT_MS_START 30
+#define GENX320_WAIT_MS_STREAM 210
+
+/*
+ * Masked register write table entry.
+ * The write helper applies: next = (cur & ~mask) | (val & mask)
+ */
+struct genx320_reg {
+	u16 addr;
+	u32 mask;
+	u32 val;
+};
+
+static const struct genx320_reg genx320_mode_default[] = {
+	/* MIPI/CSI config and EDF setup.
+	 * RPi reference: genx320_mipi_set_packet_config()
+	 * --------------------------------------------------------
+	 */
+	/* mipi_csi_frame_ctrl fixed/timeout bits = 0 */
+	{ 0xB010, 0x0000003F, 0x00000000 },
+	/* mipi_csi_ctrl default packet size = 0x1000, data type = 0x2A.
+	 * Runtime transport configuration can override the packet size later.
+	 */
+	{
+		0xB000,
+		((u32)GENX320_MIPI_PKT_SIZE_MASK
+		 << GENX320_MIPI_PKT_SIZE_SHIFT) |
+			((u32)GENX320_MIPI_DATA_TYPE_MASK
+			 << GENX320_MIPI_DATA_TYPE_SHIFT),
+		((u32)GENX320_MIPI_PKT_SIZE_DEFAULT
+		 << GENX320_MIPI_PKT_SIZE_SHIFT) |
+			((u32)GENX320_MIPI_DATA_TYPE_DEFAULT
+			 << GENX320_MIPI_DATA_TYPE_SHIFT),
+	},
+	/* edf_output_interface_control.start_of_frame_timeout = 0xFA */
+	{ 0x704C, 0x0000FFF0, 0x00000FA0 },
+	/* edf_external_output_adapter.qos_timeout=0xFFFF atomic_qos_mode=0 */
+	{ 0x7100, 0x0001FFFF, 0x0000FFFF },
+
+	/* sram_initn.mipi_initn = 1 */
+	{ 0x00B8, 0x00000020, 0x00000020 },
+	/* sram_pd1.mipi_pd */
+	{ 0x00C0, 0x00000040, 0x00000000 },
+
+	/* mipi_csi_bl_frame */
+	{ 0xB024, 0xC0FFFFFF, 0x80000680 },
