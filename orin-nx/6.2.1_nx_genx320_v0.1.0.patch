diff --git a/scripts/driver-dev-tools/bin/format-c b/scripts/driver-dev-tools/bin/format-c
new file mode 100755
index 000000000..5a24995a4
--- /dev/null
+++ b/scripts/driver-dev-tools/bin/format-c
@@ -0,0 +1,142 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+BUNDLE_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
+STYLE_FILE="$BUNDLE_ROOT/config/.clang-format"
+CHECKPATCH_WRAPPER="$SCRIPT_DIR/checkpatch-driver"
+ENFORCE_CHECKPATCH_GUARD="${FORMAT_C_ENFORCE_CHECKPATCH_GUARD:-1}"
+
+if [[ $# -eq 0 ]]; then
+	echo "Usage: format-c <file.c|file.h> [...]" >&2
+	exit 1
+fi
+
+tmp_style_dir=$(mktemp -d /tmp/format-c-style.XXXXXX)
+probe=$(mktemp /tmp/format-c-probe.XXXXXX.c)
+trap 'rm -f "$probe"; rm -rf "$tmp_style_dir"' EXIT
+
+cp "$STYLE_FILE" "$tmp_style_dir/.clang-format"
+printf 'int x;\n' > "$probe"
+
+supports_style_flag() {
+	local bin=$1
+	"$bin" --help 2>&1 | grep -q -- '-style'
+}
+
+supports_bundle_style() {
+	local bin=$1
+	"$bin" -style=file -assume-filename="$tmp_style_dir/probe.c" \
+		< "$probe" >/dev/null 2>&1
+}
+
+extract_counts() {
+	local txt=$1
+	local line
+	local errs
+	local warns
+
+	line=$(printf '%s\n' "$txt" | awk '/^total: [0-9]+ errors?, [0-9]+ warnings?,/{print; exit}')
+	[[ -n "$line" ]] || return 1
+
+	errs=$(printf '%s\n' "$line" | sed -E 's/^total: ([0-9]+) errors?, ([0-9]+) warnings?.*/\1/')
+	warns=$(printf '%s\n' "$line" | sed -E 's/^total: ([0-9]+) errors?, ([0-9]+) warnings?.*/\2/')
+	[[ "$errs" =~ ^[0-9]+$ && "$warns" =~ ^[0-9]+$ ]] || return 1
+	printf '%s %s\n' "$errs" "$warns"
+}
+
+selected=""
+default_bin=$(command -v clang-format 2>/dev/null || true)
+
+# 1) Check default clang-format first.
+if [[ -n "$default_bin" ]] \
+	&& supports_style_flag "$default_bin" \
+	&& supports_bundle_style "$default_bin"; then
+	selected="$default_bin"
+fi
+
+# 2) If default does not work, try versioned clang-format-XX binaries.
+if [[ -z "$selected" ]]; then
+	IFS=: read -r -a path_dirs <<<"$PATH"
+	mapfile -t versioned_bins < <(
+		for dir in "${path_dirs[@]}"; do
+			[[ -d "$dir" ]] || continue
+			for b in "$dir"/clang-format-[0-9]*; do
+				[[ -x "$b" ]] || continue
+				basename "$b"
+			done
+		done | sort -uV
+	)
+
+	for ((idx=${#versioned_bins[@]} - 1; idx >= 0; idx--)); do
+		bin_path=$(command -v "${versioned_bins[$idx]}" 2>/dev/null || true)
+		[[ -n "$bin_path" ]] || continue
+		[[ "$bin_path" == "$default_bin" ]] && continue
+		if supports_style_flag "$bin_path" && supports_bundle_style "$bin_path"; then
+			selected="$bin_path"
+			break
+		fi
+	done
+fi
+
+# 3) If none works, fail with clear error.
+if [[ -z "$selected" ]]; then
+	echo "format-c: no proper clang-format version was found for bundled style $STYLE_FILE" >&2
+	echo "format-c: install a newer clang-format (minimum expected: 11+)." >&2
+	exit 1
+fi
+
+if [[ -n "$default_bin" && "$selected" != "$default_bin" ]]; then
+	echo "format-c: default clang-format is incompatible; using $(basename "$selected")" >&2
+fi
+
+status=0
+for file in "$@"; do
+	if [[ ! -f "$file" ]]; then
+		echo "format-c: missing file: $file" >&2
+		status=1
+		continue
+	fi
+
+	orig=$(mktemp /tmp/format-c-orig.XXXXXX)
+	cp "$file" "$orig"
+
+	pre_counts=""
+	if [[ "$ENFORCE_CHECKPATCH_GUARD" == "1" && -x "$CHECKPATCH_WRAPPER" ]]; then
+		pre_out=$("$CHECKPATCH_WRAPPER" -f "$file" 2>&1 || true)
+		pre_counts=$(extract_counts "$pre_out" || true)
+	fi
+
+	out=$(mktemp /tmp/format-c-out.XXXXXX)
+	"$selected" -style=file \
+		-assume-filename="$tmp_style_dir/$(basename "$file")" \
+		< "$file" > "$out"
+	cat "$out" > "$file"
+	rm -f "$out"
+
+	if [[ -n "$pre_counts" ]]; then
+		post_out=$("$CHECKPATCH_WRAPPER" -f "$file" 2>&1 || true)
+		post_counts=$(extract_counts "$post_out" || true)
+		if [[ -z "$post_counts" ]]; then
+			echo "format-c: unable to parse post-format checkpatch totals for $file; restoring." >&2
+			cat "$orig" > "$file"
+			rm -f "$orig"
+			status=1
+			continue
+		fi
+
+		read -r pre_err pre_warn <<<"$pre_counts"
+		read -r post_err post_warn <<<"$post_counts"
+		if (( post_err > pre_err || post_warn > pre_warn )); then
+			echo "format-c: formatting made checkpatch worse for $file ($pre_err/$pre_warn -> $post_err/$post_warn); restoring." >&2
+			cat "$orig" > "$file"
+			rm -f "$orig"
+			status=1
+			continue
+		fi
+	fi
+
+	rm -f "$orig"
+done
+
+exit "$status"
