--- /dev/null
+++ b/nvidia-oot/tools/genx320-openeb-capture/genx320_openeb_capture.cpp
@@ -0,0 +1,311 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * GENX320 OpenEB-based headless recorder and offline renderer.
+ */
+
+#include <atomic>
+#include <chrono>
+#include <csignal>
+#include <cstdint>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <filesystem>
+#include <fstream>
+#include <iostream>
+#include <string>
+#include <thread>
+#include <vector>
+
+#include <boost/program_options.hpp>
+
+#include <metavision/sdk/base/events/event_cd.h>
+#include <metavision/sdk/core/algorithms/base_frame_generation_algorithm.h>
+#include <metavision/sdk/core/algorithms/periodic_frame_generation_algorithm.h>
+#include <metavision/sdk/stream/camera.h>
+#include <metavision/sdk/stream/file_config_hints.h>
+
+namespace po = boost::program_options;
+
+namespace {
+
+constexpr std::uint32_t kDefaultFrameUs = 10000;
+
+std::atomic<bool> g_stop_requested{false};
+
+bool psee_var_v4l2_bsize_enabled() {
+    const char *env = std::getenv("PSEE_VAR_V4L2_BSIZE");
+
+    return env && env[0] != '\0' && std::strcmp(env, "0") != 0;
+}
+
+void signal_handler(int signo) {
+    (void)signo;
+    g_stop_requested = true;
+}
+
+struct RecordOptions {
+    std::string output;
+    std::string serial;
+    std::string input_camera_config;
+    std::uint32_t duration_ms{0};
+};
+
+struct RenderOptions {
+    std::string input;
+    std::string output;
+    std::uint32_t frame_us{kDefaultFrameUs};
+};
+
+class RawVideoWriter {
+public:
+    RawVideoWriter(std::uint32_t width, std::uint32_t height, const std::string &output_path) :
+        width_(width), height_(height) {
+        output_.open(output_path, std::ios::binary | std::ios::trunc);
+        if (!output_) {
+            throw std::runtime_error("Failed to open output file: " + output_path);
+        }
+    }
+
+    void write_frame(const cv::Mat &frame) {
+        if (frame.cols != static_cast<int>(width_) || frame.rows != static_cast<int>(height_)) {
+            throw std::runtime_error("Frame geometry mismatch while rendering");
+        }
+
+        if (frame.type() != CV_8UC1) {
+            throw std::runtime_error("Expected CV_8UC1 frame from OpenEB renderer");
+        }
+
+        if (frame.isContinuous()) {
+            output_.write(reinterpret_cast<const char *>(frame.data),
+                          static_cast<std::streamsize>(frame.total() * frame.elemSize()));
+        } else {
+            for (int row = 0; row < frame.rows; ++row) {
+                output_.write(reinterpret_cast<const char *>(frame.ptr(row)),
+                              static_cast<std::streamsize>(frame.cols * frame.elemSize()));
+            }
+        }
+
+        if (!output_) {
+            throw std::runtime_error("Failed while writing rendered output");
+        }
+
+        frame_index_++;
+    }
+
+    std::uint32_t frame_count() const {
+        return frame_index_;
+    }
+
+    std::uint32_t width_;
+    std::uint32_t height_;
+    std::uint32_t frame_index_{0};
+    std::ofstream output_;
+};
+
+Metavision::Camera open_live_camera(const RecordOptions &opts) {
+    if (!opts.serial.empty()) {
+        return Metavision::Camera::from_serial(opts.serial);
+    }
+
+    return Metavision::Camera::from_first_available();
+}
+
+int run_record(const RecordOptions &opts) {
+    if (!psee_var_v4l2_bsize_enabled()) {
+        std::cerr
+            << "Warning: PSEE_VAR_V4L2_BSIZE is not set. On Jetson tegra-video "
+            << "EVT21 capture, this can record stale V4L2 buffer tail data and "
+            << "cause \"Error TimeHigh discrepancy\" during offline decode.\n"
+            << "Set: export PSEE_VAR_V4L2_BSIZE=1\n";
+    }
+
+    Metavision::Camera camera = open_live_camera(opts);
+
+    if (!opts.input_camera_config.empty()) {
+        if (!camera.load(opts.input_camera_config)) {
+            std::cerr << "Failed to load camera config from "
+                      << opts.input_camera_config << '\n';
+            return 1;
+        }
+    }
+
+    if (!camera.start_recording(opts.output)) {
+        std::cerr << "Failed to start recording to " << opts.output << '\n';
+        return 1;
+    }
+
+    std::cout << "Recording to " << opts.output;
+    if (opts.duration_ms != 0) {
+        std::cout << " for " << opts.duration_ms << " ms";
+    }
+    std::cout << '\n';
+
+    camera.start();
+
+    const auto start = std::chrono::steady_clock::now();
+    while (!g_stop_requested && camera.is_running()) {
+        if (opts.duration_ms != 0) {
+            const auto elapsed = std::chrono::duration_cast<std::chrono::milliseconds>(
+                std::chrono::steady_clock::now() - start);
+            if (elapsed.count() >= opts.duration_ms) {
+                break;
+            }
+        }
+
+        std::this_thread::sleep_for(std::chrono::milliseconds(50));
+    }
+
+    camera.stop_recording(opts.output);
+    camera.stop();
+
+    while (camera.is_running()) {
+        std::this_thread::sleep_for(std::chrono::milliseconds(20));
+    }
+
+    std::cout << "Recording finished: " << opts.output << '\n';
+    return 0;
+}
+
+int run_render(const RenderOptions &opts) {
+    Metavision::Camera camera = Metavision::Camera::from_file(
+        opts.input, Metavision::FileConfigHints().real_time_playback(false));
+
+    const auto &geometry = camera.geometry();
+    RawVideoWriter writer(static_cast<std::uint32_t>(geometry.get_width()),
+                          static_cast<std::uint32_t>(geometry.get_height()), opts.output);
+    Metavision::PeriodicFrameGenerationAlgorithm frame_generation(geometry.get_width(), geometry.get_height(),
+                                                                  opts.frame_us, 1000000.0 / opts.frame_us);
+
+    frame_generation.set_parameters(Metavision::ColorPalette::Gray,
+                                    Metavision::BaseFrameGenerationAlgorithm::GRAY);
+    frame_generation.set_output_callback([&writer](Metavision::timestamp, cv::Mat &frame) {
+        writer.write_frame(frame);
+    });
+
+    camera.cd().add_callback([&frame_generation](const Metavision::EventCD *begin, const Metavision::EventCD *end) {
+        frame_generation.process_events(begin, end);
+    });
+
+    camera.start();
+
+    while (camera.is_running()) {
+        std::this_thread::sleep_for(std::chrono::milliseconds(20));
+    }
+
+    frame_generation.force_generate();
+
+    std::cout << "Rendered " << writer.frame_count() << " frames into " << opts.output << " ("
+              << geometry.get_width() << "x" << geometry.get_height() << " Y8, "
+              << (1000000.0 / static_cast<double>(opts.frame_us)) << " fps)\n";
+    return 0;
+}
+
+int parse_record_options(int argc, char **argv, RecordOptions &opts) {
+    po::options_description desc("Record options");
+    po::variables_map vm;
+
+    desc.add_options()("help,h", "Produce help message.")(
+        "output,o", po::value<std::string>(&opts.output)->required(), "Output RAW file.")(
+        "serial,s", po::value<std::string>(&opts.serial), "Camera serial.")(
+        "input-camera-config,j",
+        po::value<std::string>(&opts.input_camera_config),
+        "Path to a JSON camera config file to load before recording.")(
+        "duration-ms", po::value<std::uint32_t>(&opts.duration_ms), "Recording duration in milliseconds.");
+
+    try {
+        po::store(po::command_line_parser(argc, argv).options(desc).run(), vm);
+        if (vm.count("help")) {
+            std::cout << desc << '\n';
+            return 1;
+        }
+        po::notify(vm);
+    } catch (const std::exception &e) {
+        std::cerr << "record: " << e.what() << '\n' << desc << '\n';
+        return -1;
+    }
+
+    return 0;
+}
+
+int parse_render_options(int argc, char **argv, RenderOptions &opts) {
+    po::options_description desc("Render options");
+    po::variables_map vm;
+
+    desc.add_options()("help,h", "Produce help message.")(
+        "input,i", po::value<std::string>(&opts.input)->required(), "Input RAW or HDF5 file.")(
+        "output,o", po::value<std::string>(&opts.output)->required(), "Output Y8 frame stream.")(
+        "frame-us", po::value<std::uint32_t>(&opts.frame_us)->default_value(kDefaultFrameUs),
+        "Aggregation window in microseconds.");
+
+    try {
+        po::store(po::command_line_parser(argc, argv).options(desc).run(), vm);
+        if (vm.count("help")) {
+            std::cout << desc << '\n';
+            return 1;
+        }
+        po::notify(vm);
+    } catch (const std::exception &e) {
+        std::cerr << "render: " << e.what() << '\n' << desc << '\n';
+        return -1;
+    }
+
+    if (opts.frame_us == 0) {
+        std::cerr << "render: --frame-us must be greater than 0\n";
+        return -1;
+    }
+
+    return 0;
+}
+
+void print_usage(const char *prog) {
+    std::cerr << "Usage:\n"
+              << "  " << prog << " record [options]\n"
+              << "  " << prog << " render [options]\n";
+}
+
+} // namespace
+
+int main(int argc, char **argv) {
+    std::signal(SIGINT, signal_handler);
+    std::signal(SIGTERM, signal_handler);
+
+    if (argc < 2) {
+        print_usage(argv[0]);
+        return EXIT_FAILURE;
+    }
+
+    try {
+        const std::string command(argv[1]);
+
+        if (command == "record") {
+            RecordOptions opts;
+            const int ret = parse_record_options(argc - 1, argv + 1, opts);
+            if (ret > 0) {
+                return EXIT_SUCCESS;
+            }
+            if (ret < 0) {
+                return EXIT_FAILURE;
+            }
+            return run_record(opts);
+        }
+
+        if (command == "render") {
+            RenderOptions opts;
+            const int ret = parse_render_options(argc - 1, argv + 1, opts);
+            if (ret > 0) {
+                return EXIT_SUCCESS;
+            }
+            if (ret < 0) {
+                return EXIT_FAILURE;
+            }
+            return run_render(opts);
+        }
+    } catch (const std::exception &e) {
+        std::cerr << e.what() << '\n';
+        return EXIT_FAILURE;
+    }
+
+    print_usage(argv[0]);
+    return EXIT_FAILURE;
+}
diff --git a/scripts/build_l4t.sh b/scripts/build_l4t.sh
new file mode 100755
index 000000000..aae7e5cd8
--- /dev/null
+++ b/scripts/build_l4t.sh
@@ -0,0 +1,562 @@
+#!/usr/bin/env bash
+
+usage() {
+	cat <<'EOF'
+Usage:
+  ./build_l4t.sh <toolchain-path>
+
+Description:
+  Run from L4T source root (the directory containing kernel/, nvidia-oot/, hardware/).
+  The script exports build environment variables and builds:
+  1) Kernel image
+  2) In-tree module install to rootfs/
+  3) NVIDIA out-of-tree modules
+  4) Module install to rootfs/
+  5) DTBs/DTBOs
+
+Source mode:
+  source ./scripts/build_l4t.sh <toolchain-path>
+  build_l4t_build_all
+  (pre-commit setup runs automatically when sourced)
+  (if no argument is provided, toolchain is resolved from .env TOOLCHAIN_ROOT)
+  (if toolchain setup fails, sourcing continues so helper functions remain available)
+
+Available commands:
+  build_l4t_set_source_root [source-root]
+    Validate/set source root (defaults to script parent directory on first call).
+  build_l4t_download_toolchain <install-root>
+    Download/extract Bootlin toolchain, set TOOLCHAIN_ROOT, and prepare environment.
+  build_l4t_prepare_environment <toolchain-path>
+    Resolve toolchain (argument preferred, then .env TOOLCHAIN_ROOT),
+    export build env vars, create rootfs/boot staging dir.
+  build_l4t_deactivate_environment
+    Restore original prompt (if tagged) and clear build-ready marker.
+  build <target>
+    Target build command. Targets: kernel | modules | dtbs | all
+  stage <target>
+    Target staging/install command. Targets: kernel | modules | precommit | all
+  build_l4t_register_completions
+    Register bash completion for build/stage targets (source mode, interactive shell).
+
+Exported artifact path variables
+  (set by build_l4t_prepare_environment):
+  BUILD_L4T_KERNEL_IMAGE_PATH
+  BUILD_L4T_DRIVER_MODULE_PATH
+  BUILD_L4T_DTBO_PATH
+EOF
+}
+
+build_l4t_fail() {
+	echo "Error: $*" >&2
+	return 1
+}
+
+build_l4t_default_source_root() {
+	local script_dir
+	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+	cd "$script_dir/.." && pwd
+}
+
+build_l4t_print_toolchain_download_hint() {
+	local suggested_root="${1:-$HOME/l4t-gcc}"
+
+	echo "Toolchain setup helper:" >&2
+	echo "  source ./scripts/build_l4t.sh" >&2
+	echo "  build_l4t_download_toolchain \"$suggested_root\"" >&2
+}
+
+build_l4t_print_environment_setup_hint() {
+	local suggested_root="${1:-${TOOLCHAIN_ROOT:-$HOME/l4t-gcc}}"
+	local env_file
+
+	env_file="$(build_l4t_get_env_file_path)"
+
+	echo "Environment is not prepared. Build/stage commands will fail until toolchain setup is fixed." >&2
+	echo "Configure with one of these:" >&2
+	echo "  source ./scripts/build_l4t.sh <toolchain-path>" >&2
+	echo "  set TOOLCHAIN_ROOT in \"$env_file\" and run: build_l4t_prepare_environment" >&2
+	echo "  build_l4t_download_toolchain \"$suggested_root\"" >&2
+}
+
+build_l4t_get_env_file_path() {
+	if [[ -n "${BUILD_L4T_SOURCE_ROOT:-}" ]]; then
+		echo "$BUILD_L4T_SOURCE_ROOT/.env"
+	else
+		echo "$(build_l4t_default_source_root)/.env"
+	fi
+}
+
+build_l4t_read_toolchain_from_env_file() {
+	local env_file
+	local value
+
+	env_file="$(build_l4t_get_env_file_path)"
+	[[ -f "$env_file" ]] || return 1
+
+	value="$(sed -n 's/^[[:space:]]*\(export[[:space:]]\+\)\?TOOLCHAIN_ROOT[[:space:]]*=[[:space:]]*//p' "$env_file" | tail -n 1)"
+	[[ -n "$value" ]] || return 1
+
+	value="$(printf '%s' "$value" | sed 's/[[:space:]]*#.*$//; s/^[[:space:]]*//; s/[[:space:]]*$//')"
+	if [[ "$value" == \"* ]]; then
+		value="${value#\"}"
+		value="${value%\"}"
+	elif [[ "$value" == \'* ]]; then
+		value="${value#\'}"
+		value="${value%\'}"
+	fi
+
+	[[ -n "$value" ]] || return 1
+	BUILD_L4T_ENV_FILE_TOOLCHAIN_PATH="$value"
+	return 0
+}
+
+build_l4t_write_toolchain_to_env_file() {
+	local toolchain_path="${1:-}"
+	local env_file
+	local escaped
+	local tmp_file
+
+	[[ -n "$toolchain_path" ]] || return 1
+
+	env_file="$(build_l4t_get_env_file_path)"
+	escaped="${toolchain_path//\"/\\\"}"
+	tmp_file="${env_file}.tmp.$$"
+
+	if [[ -f "$env_file" ]] && grep -Eq '^[[:space:]]*(export[[:space:]]+)?TOOLCHAIN_ROOT[[:space:]]*=' "$env_file"; then
+		sed -E "s|^[[:space:]]*(export[[:space:]]+)?TOOLCHAIN_ROOT[[:space:]]*=.*$|TOOLCHAIN_ROOT=\"$escaped\"|" "$env_file" > "$tmp_file" || return 1
+	elif [[ -f "$env_file" ]]; then
+		cat "$env_file" > "$tmp_file" || return 1
+		{
+			echo ""
+			echo "# Added by scripts/build_l4t.sh"
+			echo "TOOLCHAIN_ROOT=\"$escaped\""
+		} >> "$tmp_file"
+	else
+		{
+			echo "# Auto-generated by scripts/build_l4t.sh"
+			echo "TOOLCHAIN_ROOT=\"$escaped\""
+		} > "$tmp_file"
+	fi
+
+	mv "$tmp_file" "$env_file" || return 1
+	echo "Saved toolchain path to $env_file"
+	return 0
+}
+
+build_l4t_download_toolchain() {
+	local install_root="${1:-}"
+	local archive_url="${BUILD_L4T_TOOLCHAIN_URL:-https://toolchains.bootlin.com/downloads/releases/toolchains/aarch64/tarballs/aarch64--glibc--stable-2022.08-1.tar.bz2}"
+	local archive_name="${archive_url##*/}"
+	local archive_path=""
+
+	if [[ -z "$install_root" ]]; then
+		build_l4t_fail "missing install root argument"
+		echo "Usage: build_l4t_download_toolchain <install-root>" >&2
+		return 1
+	fi
+
+	install_root="${install_root%/}"
+	archive_path="$install_root/$archive_name"
+
+	mkdir -p "$install_root" || return 1
+
+	echo "Downloading toolchain archive:"
+	echo "- URL: $archive_url"
+	echo "- Destination: $archive_path"
+
+	if command -v wget >/dev/null 2>&1; then
+		wget -O "$archive_path" "$archive_url" || return 1
+	elif command -v curl >/dev/null 2>&1; then
+		curl -L "$archive_url" -o "$archive_path" || return 1
+	else
+		build_l4t_fail "missing downloader: install wget or curl"
+		return 1
+	fi
+
+	tar -xf "$archive_path" -C "$install_root" || return 1
+
+	export TOOLCHAIN_ROOT="$install_root"
+	BUILD_L4T_TOOLCHAIN_PATH="$install_root"
+	export BUILD_L4T_TOOLCHAIN_PATH
+
+	echo "Toolchain extracted under: $install_root"
+	echo "Preparing build environment from downloaded toolchain..."
+
+	if ! build_l4t_prepare_environment "$install_root"; then
+		build_l4t_print_environment_setup_hint "$install_root"
+		return 1
+	fi
+
+	echo "Toolchain and build environment are ready."
+	return 0
+}
+
+build_l4t_is_interactive_shell() {
+	[[ $- == *i* ]]
+}
+
+build_l4t_activate_prompt_tag() {
+	local prompt_tag="${BUILD_L4T_PROMPT_TAG:-[L4T-BUILD]}"
+
+	build_l4t_is_interactive_shell || return 0
+
+	if [[ "${BUILD_L4T_PROMPT_ACTIVE:-0}" == "1" ]]; then
+		return 0
+	fi
+
+	BUILD_L4T_OLD_PS1="${PS1-}"
+	PS1="$prompt_tag ${PS1-}"
+	BUILD_L4T_PROMPT_ACTIVE=1
+	export BUILD_L4T_OLD_PS1 BUILD_L4T_PROMPT_ACTIVE
+	return 0
+}
+
+build_l4t_deactivate_environment() {
+	if build_l4t_is_interactive_shell && [[ "${BUILD_L4T_PROMPT_ACTIVE:-0}" == "1" ]]; then
+		PS1="${BUILD_L4T_OLD_PS1-}"
+		unset BUILD_L4T_OLD_PS1
+		unset BUILD_L4T_PROMPT_ACTIVE
+	fi
+
+	BUILD_L4T_ENV_READY=0
+	return 0
+}
+
+build_l4t_set_source_root() {
+	local source_root=""
+
+	if [[ -n "${1:-}" ]]; then
+		source_root="$1"
+	elif [[ -n "${BUILD_L4T_SOURCE_ROOT:-}" ]]; then
+		source_root="$BUILD_L4T_SOURCE_ROOT"
+	else
+		source_root="$(build_l4t_default_source_root)"
+	fi
+
+	source_root="${source_root%/}"
+
+	if [[ ! -d "$source_root/kernel" || ! -d "$source_root/nvidia-oot" || ! -d "$source_root/hardware" ]]; then
+		build_l4t_fail "invalid L4T source root: $source_root"
+		echo "Expected directories: kernel/, nvidia-oot/, hardware/" >&2
+		return 1
+	fi
+
+	BUILD_L4T_SOURCE_ROOT="$source_root"
+	return 0
+}
+
+build_l4t_resolve_toolchain() {
+	local toolchain_path="${1%/}"
+
+	if [[ -z "$toolchain_path" ]]; then
+		build_l4t_fail "missing toolchain path argument"
+		build_l4t_print_toolchain_download_hint
+		return 1
+	fi
+
+	if [[ ! -d "$toolchain_path" ]]; then
+		build_l4t_fail "toolchain path does not exist: $toolchain_path"
+		build_l4t_print_toolchain_download_hint "$toolchain_path"
+		return 1
+	fi
+
+	if [[ -x "$toolchain_path/bin/aarch64-buildroot-linux-gnu-gcc" ]]; then
+		BUILD_L4T_CROSS_PREFIX="$toolchain_path/bin/aarch64-buildroot-linux-gnu-"
+	elif [[ -x "$toolchain_path/aarch64--glibc--stable-2022.08-1/bin/aarch64-buildroot-linux-gnu-gcc" ]]; then
+		BUILD_L4T_CROSS_PREFIX="$toolchain_path/aarch64--glibc--stable-2022.08-1/bin/aarch64-buildroot-linux-gnu-"
+	else
+		build_l4t_fail "could not find aarch64-buildroot-linux-gnu-gcc under $toolchain_path"
+		echo "Pass either the extracted toolchain root, or its parent directory." >&2
+		build_l4t_print_toolchain_download_hint "$toolchain_path"
+		return 1
+	fi
+
+	BUILD_L4T_TOOLCHAIN_PATH="$toolchain_path"
+	return 0
+}
+
+build_l4t_run_in_source_root() {
+	local old_pwd="$PWD"
+	local status=0
+
+	cd "$BUILD_L4T_SOURCE_ROOT" || return 1
+	"$@" || status=$?
+	cd "$old_pwd" || return 1
+
+	return "$status"
+}
+
+build_l4t_set_artifact_paths() {
+	BUILD_L4T_KERNEL_IMAGE_PATH="$BUILD_L4T_SOURCE_ROOT/kernel/kernel-jammy-src/arch/arm64/boot/Image"
+	BUILD_L4T_DRIVER_MODULE_PATH="$BUILD_L4T_SOURCE_ROOT/nvidia-oot/drivers/media/i2c/nv_genx320.ko"
+	BUILD_L4T_DTBO_PATH="$BUILD_L4T_SOURCE_ROOT/kernel-devicetree/generic-dts/dtbs/tegra234-p3767-camera-p3768-genx320-A.dtbo"
+
+	export BUILD_L4T_KERNEL_IMAGE_PATH
+	export BUILD_L4T_DRIVER_MODULE_PATH
+	export BUILD_L4T_DTBO_PATH
+}
+
+build_l4t_prepare_environment() {
+	local requested_toolchain_path="${1:-}"
+	local toolchain_path=""
+	local env_file=""
+
+	build_l4t_set_source_root || return 1
+	env_file="$(build_l4t_get_env_file_path)"
+
+	if [[ -n "$requested_toolchain_path" ]]; then
+		toolchain_path="$requested_toolchain_path"
+	elif build_l4t_read_toolchain_from_env_file; then
+		toolchain_path="$BUILD_L4T_ENV_FILE_TOOLCHAIN_PATH"
+	else
+		build_l4t_fail "missing toolchain path argument and no TOOLCHAIN_ROOT entry found in $env_file"
+		build_l4t_print_environment_setup_hint
+		return 1
+	fi
+
+	build_l4t_resolve_toolchain "$toolchain_path" || return 1
+
+	export TOOLCHAIN_ROOT="$BUILD_L4T_TOOLCHAIN_PATH"
+	export BUILD_L4T_EXPLICIT_TOOLCHAIN_PATH="$BUILD_L4T_TOOLCHAIN_PATH"
+	export CROSS_COMPILE="$BUILD_L4T_CROSS_PREFIX"
+	export KERNEL_HEADERS="$BUILD_L4T_SOURCE_ROOT/kernel/kernel-jammy-src"
+	export INSTALL_MOD_PATH="$BUILD_L4T_SOURCE_ROOT/rootfs"
+
+	if [[ -n "$requested_toolchain_path" ]]; then
+		build_l4t_write_toolchain_to_env_file "$BUILD_L4T_TOOLCHAIN_PATH" || return 1
+	fi
+
+	build_l4t_set_artifact_paths
+
+	mkdir -p "$INSTALL_MOD_PATH/boot"
+
+	echo "Prepared build environment:"
+	echo "- BUILD_L4T_SOURCE_ROOT=$BUILD_L4T_SOURCE_ROOT"
+	echo "- TOOLCHAIN_ROOT=$TOOLCHAIN_ROOT"
+	echo "- CROSS_COMPILE=$CROSS_COMPILE"
+	echo "- KERNEL_HEADERS=$KERNEL_HEADERS"
+	echo "- INSTALL_MOD_PATH=$INSTALL_MOD_PATH"
+	echo "- BUILD_L4T_KERNEL_IMAGE_PATH=$BUILD_L4T_KERNEL_IMAGE_PATH"
+	echo "- BUILD_L4T_DRIVER_MODULE_PATH=$BUILD_L4T_DRIVER_MODULE_PATH"
+	echo "- BUILD_L4T_DTBO_PATH=$BUILD_L4T_DTBO_PATH"
+
+	if build_l4t_is_sourced; then
+		build_l4t_activate_prompt_tag
+	fi
+
+	BUILD_L4T_ENV_READY=1
+	return 0
+}
+
+build_l4t_require_environment() {
+	if [[ "${BUILD_L4T_ENV_READY:-0}" == "1" ]]; then
+		return 0
+	fi
+
+	if [[ -z "${BUILD_L4T_EXPLICIT_TOOLCHAIN_PATH:-}" ]]; then
+		build_l4t_fail "environment is not prepared and no explicit toolchain path is configured"
+		build_l4t_print_environment_setup_hint
+		return 1
+	fi
+
+	if ! build_l4t_prepare_environment "$BUILD_L4T_EXPLICIT_TOOLCHAIN_PATH"; then
+		build_l4t_print_environment_setup_hint "$BUILD_L4T_EXPLICIT_TOOLCHAIN_PATH"
+		return 1
+	fi
+	return 0
+}
+
+build_l4t_build_kernel() {
+	build_l4t_require_environment || return 1
+	echo "Building kernel"
+	build_l4t_run_in_source_root make -C kernel
+}
+
+build_l4t_install_kernel_modules() {
+	build_l4t_require_environment || return 1
+	echo "Installing kernel and in-tree modules to rootfs/"
+	build_l4t_run_in_source_root make -C kernel install
+}
+
+build_l4t_build_oot_modules() {
+	build_l4t_require_environment || return 1
+	echo "Building NVIDIA out-of-tree modules"
+	build_l4t_run_in_source_root make modules
+}
+
+build_l4t_install_oot_modules() {
+	build_l4t_require_environment || return 1
+	echo "Installing modules to rootfs/"
+	build_l4t_run_in_source_root make modules_install
+}
+
+build_l4t_build_dtbs() {
+	build_l4t_require_environment || return 1
+	echo "Building DTBs/DTBOs"
+	build_l4t_run_in_source_root make dtbs
+}
+
+build_l4t_install_precommit() {
+	build_l4t_set_source_root || return 1
+	echo "Installing pre-commit and hooks"
+	build_l4t_run_in_source_root python3 -m pip install --user pre-commit || return 1
+	build_l4t_run_in_source_root python3 -m pre_commit install --install-hooks
+}
+
+build() {
+	local target="${1:-}"
+
+	build_l4t_require_environment || return 1
+
+	case "$target" in
+		kernel)
+			build_l4t_build_kernel
+			;;
+		modules|oot-modules)
+			build_l4t_build_oot_modules
+			;;
+		dtb|dtbs|dtbo|dtbos)
+			build_l4t_build_dtbs
+			;;
+		all)
+			build_l4t_build_all
+			;;
+		*)
+			build_l4t_fail "unknown build target: '$target'"
+			echo "Valid build targets: kernel | modules | dtbs | all" >&2
+			return 1
+			;;
+	esac
+}
+
+stage() {
+	local target="${1:-}"
+
+	case "$target" in
+		kernel|kernel-modules|in-tree)
+			build_l4t_require_environment || return 1
+			build_l4t_install_kernel_modules
+			;;
+		modules|oot-modules)
+			build_l4t_require_environment || return 1
+			build_l4t_install_oot_modules
+			;;
+		precommit|hooks)
+			build_l4t_install_precommit
+			;;
+		all)
+			build_l4t_require_environment || return 1
+			build_l4t_install_kernel_modules || return 1
+			build_l4t_install_oot_modules
+			;;
+		*)
+			build_l4t_fail "unknown stage target: '$target'"
+			echo "Valid stage targets: kernel | modules | precommit | all" >&2
+			return 1
+			;;
+	esac
+}
+
+build_l4t_complete_build() {
+	local cur="${COMP_WORDS[COMP_CWORD]}"
+	local targets="kernel modules dtbs all"
+	COMPREPLY=( $(compgen -W "$targets" -- "$cur") )
+}
+
+build_l4t_complete_stage() {
+	local cur="${COMP_WORDS[COMP_CWORD]}"
+	local targets="kernel modules precommit all"
+	COMPREPLY=( $(compgen -W "$targets" -- "$cur") )
+}
+
+build_l4t_register_completions() {
+	# Bash-only, interactive-shell-only convenience.
+	build_l4t_is_interactive_shell || return 0
+	if [[ -n "${BASH_VERSION:-}" ]]; then
+		complete -F build_l4t_complete_build build
+		complete -F build_l4t_complete_stage stage
+	fi
+	return 0
+}
+
+build_l4t_print_artifacts() {
+	cat <<EOF
+Build complete.
+
+Artifacts:
+- Kernel image: $BUILD_L4T_KERNEL_IMAGE_PATH
+- Sensor module: $BUILD_L4T_DRIVER_MODULE_PATH
+- DTBs/DTBOs: $BUILD_L4T_SOURCE_ROOT/kernel-devicetree/generic-dts/dtbs/
+- Expected overlay: $BUILD_L4T_DTBO_PATH
+EOF
+}
+
+build_l4t_build_all() {
+	build_l4t_require_environment || return 1
+
+	echo "[1/5]"
+	build_l4t_build_kernel || return 1
+
+	echo "[2/5]"
+	build_l4t_install_kernel_modules || return 1
+
+	echo "[3/5]"
+	build_l4t_build_oot_modules || return 1
+
+	echo "[4/5]"
+	build_l4t_install_oot_modules || return 1
+
+	echo "[5/5]"
+	build_l4t_build_dtbs || return 1
+
+	build_l4t_print_artifacts
+	return 0
+}
+
+build_l4t_is_sourced() {
+	[[ "${BASH_SOURCE[0]}" != "${0}" ]]
+}
+
+if build_l4t_is_sourced; then
+	if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
+		usage
+		return 0
+	fi
+
+	if [[ $# -gt 1 ]]; then
+		build_l4t_fail "source mode accepts at most one argument: <toolchain-path>"
+		usage
+		return 1
+	fi
+
+	if [[ $# -eq 1 ]]; then
+		if ! build_l4t_prepare_environment "$1"; then
+			build_l4t_print_environment_setup_hint "$1"
+		fi
+	else
+		build_l4t_prepare_environment || true
+	fi
+
+	if ! build_l4t_install_precommit; then
+		echo "Pre-commit setup skipped: source root is not ready." >&2
+	fi
+
+	build_l4t_register_completions
+
+	usage
+else
+	set -euo pipefail
+
+	if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
+		usage
+		exit 0
+	fi
+
+	if [[ $# -ne 1 ]]; then
+		usage
+		exit 1
+	fi
+
+	build_l4t_prepare_environment "$1"
+	build_l4t_build_all
+fi
diff --git a/scripts/driver-dev-tools/README.md b/scripts/driver-dev-tools/README.md
new file mode 100644
index 000000000..74e74e738
--- /dev/null
+++ b/scripts/driver-dev-tools/README.md
@@ -0,0 +1,116 @@
+# Driver Dev Tools Bundle
+
+This bundle packages a small, reusable subset of Linux kernel helper scripts for out-of-tree driver development.
+
+## Included tools
+
+- `bin/checkpatch-driver`: wrapper around kernel `checkpatch.pl`
+- `bin/format-c`: format C/H files using kernel `.clang-format`
+- `bin/lint-c`: run C/H checks (`checkpatch`, `checkincludes`, `checkdeclares`)
+- `bin/lint-dt`: style-only lint for DTS/DTSI via `checkpatch`
+- `bin/lint-kconfig`: basic Kconfig style checks via `checkpatch`
+- `bin/extract-compatibles`: extract DT compatible strings from C files
+- `bin/lint-all`: recurse and lint C/H + DTS/DTSI + Kconfig
+- `bin/install-systemwide`: install symlinks to `~/.local/bin` (or custom prefix)
+- `bin/sync-from-kernel.sh`: refresh vendored scripts from a kernel tree
+
+Vendored kernel scripts live under `tools/linux/` and formatting config is in `config/.clang-format`.
+
+## Dependencies
+
+Install these system tools:
+
+- `perl`
+- `python3`
+- `clang-format`
+
+Optional (for deeper analysis outside this bundle):
+
+- `sparse`
+- `clang-tidy`
+
+## Usage
+
+### 1) Check one C file
+
+```bash
+scripts/driver-dev-tools/bin/checkpatch-driver -f file.c
+```
+
+By default this wrapper ignores:
+
+- `UNDOCUMENTED_DT_STRING`
+
+Override ignore list:
+
+```bash
+CHECKPATCH_IGNORE_TYPES="" scripts/driver-dev-tools/bin/checkpatch-driver -f file.c
+```
+
+### 2) Format C/H files
+
+```bash
+scripts/driver-dev-tools/bin/format-c path/to/file.c path/to/file.h
+```
+
+`format-c` selects the formatter automatically:
+1. Try default `clang-format` in `PATH`.
+2. If incompatible, try installed `clang-format-XX` binaries.
+3. If none can parse the bundled `.clang-format`, it exits with an error.
+
+### 3) Lint C/H files
+
+```bash
+scripts/driver-dev-tools/bin/lint-c path/to/file.c path/to/file.h
+```
+
+### 4) Lint DTS/DTSI files
+
+```bash
+scripts/driver-dev-tools/bin/lint-dt path/to/file.dts path/to/file.dtsi
+```
+
+### 5) Lint Kconfig files
+
+```bash
+scripts/driver-dev-tools/bin/lint-kconfig path/to/Kconfig
+```
+
+### 6) Lint an entire subtree
+
+```bash
+scripts/driver-dev-tools/bin/lint-all nvidia-oot
+```
+
+## System-wide availability
+
+Create symlinks in `~/.local/bin`:
+
+```bash
+scripts/driver-dev-tools/bin/install-systemwide
+```
+
+Or custom prefix:
+
+```bash
+scripts/driver-dev-tools/bin/install-systemwide /usr/local/bin
+```
+
+## Refresh from another kernel tree
+
+```bash
+scripts/driver-dev-tools/bin/sync-from-kernel.sh /path/to/linux
+```
+
+## Notes
+
+- `checkpatch-driver` runs with `--no-tree` by default for out-of-tree repos.
+- To run tree-aware checks, set:
+
+```bash
+CHECKPATCH_NO_TREE=0 CHECKPATCH_TREE_ROOT=/path/to/linux \
+  scripts/driver-dev-tools/bin/checkpatch-driver -f file.c
+```
+
+- `lint-dt` is style-only and does not resolve includes/macros.
+- If you later need semantic DT validation, use `dtc`/`dtschema` against your target kernel/BSP tree.
diff --git a/scripts/driver-dev-tools/bin/checkpatch-driver b/scripts/driver-dev-tools/bin/checkpatch-driver
new file mode 100755
index 000000000..5668364a9
--- /dev/null
+++ b/scripts/driver-dev-tools/bin/checkpatch-driver
@@ -0,0 +1,38 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+BUNDLE_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
+CHECKPATCH="$BUNDLE_ROOT/tools/linux/checkpatch.pl"
+
+if [[ $# -eq 0 ]]; then
+	cat >&2 <<'USAGE'
+Usage: checkpatch-driver [checkpatch options] <file-or-patch>
+
+Examples:
+  checkpatch-driver -f path/to/file.c
+  checkpatch-driver --strict -f path/to/file.c
+
+Environment:
+  CHECKPATCH_IGNORE_TYPES   Comma-separated type list to ignore.
+                            Default: UNDOCUMENTED_DT_STRING
+  CHECKPATCH_NO_TREE        Set to 1 to force --no-tree (default: 1)
+  CHECKPATCH_TREE_ROOT      Optional kernel tree path for tree-aware checks
+USAGE
+	exit 1
+fi
+
+cmd=("$CHECKPATCH" --show-types)
+
+if [[ "${CHECKPATCH_NO_TREE:-1}" == "1" ]]; then
+	cmd+=(--no-tree)
+elif [[ -n "${CHECKPATCH_TREE_ROOT:-}" ]]; then
+	cmd+=(--root "${CHECKPATCH_TREE_ROOT}")
+fi
+
+if [[ -n "${CHECKPATCH_IGNORE_TYPES:-UNDOCUMENTED_DT_STRING}" ]]; then
+	cmd+=(--ignore "${CHECKPATCH_IGNORE_TYPES:-UNDOCUMENTED_DT_STRING}")
+fi
+
+cmd+=("$@")
+exec "${cmd[@]}"
