--- /dev/null
+++ b/scripts/driver-dev-tools/bin/lint-dt
@@ -0,0 +1,58 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+CHECKPATCH_WRAPPER="$SCRIPT_DIR/checkpatch-driver"
+
+usage() {
+	cat >&2 <<'USAGE'
+Usage: lint-dt <file.dts|file.dtsi> [...]
+
+Notes:
+  - Style-only linting via checkpatch
+  - No include/macro resolution is performed
+USAGE
+}
+
+files=()
+
+while [[ $# -gt 0 ]]; do
+	case "$1" in
+		-h|--help)
+			usage
+			exit 0
+			;;
+		-I)
+			# Kept for backward compatibility with older usage.
+			[[ $# -ge 2 ]] || { usage; exit 1; }
+			echo "lint-dt: ignoring -I '$2' (style-only mode)" >&2
+			shift 2
+			;;
+		*)
+			files+=("$1")
+			shift
+			;;
+	esac
+done
+
+if [[ ${#files[@]} -eq 0 ]]; then
+	usage
+	exit 1
+fi
+
+status=0
+
+for file in "${files[@]}"; do
+	if [[ ! -f "$file" ]]; then
+		echo "missing file: $file" >&2
+		status=1
+		continue
+	fi
+
+	echo "[lint-dt] $file"
+	if ! "$CHECKPATCH_WRAPPER" -f "$file"; then
+		status=1
+	fi
+done
+
+exit "$status"
