+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+PREFIX=${1:-"$HOME/.local/bin"}
+
+mkdir -p "$PREFIX"
+for tool in checkpatch-driver format-c lint-c lint-dt lint-kconfig extract-compatibles; do
+	ln -sfn "$SCRIPT_DIR/$tool" "$PREFIX/$tool"
+	echo "linked $PREFIX/$tool"
+done
+
+echo
+echo "If needed, add to PATH: export PATH=\"$PREFIX:\$PATH\""
