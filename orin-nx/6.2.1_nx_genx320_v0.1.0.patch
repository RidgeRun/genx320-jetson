+
+static int xioctl(int fd, unsigned long request, void *arg)
+{
+	int ret;
+
+	do {
+		ret = ioctl(fd, request, arg);
+	} while (ret == -1 && errno == EINTR);
+
+	return ret;
+}
+
+static const struct known_control *find_known_control(const char *name)
+{
+	size_t i;
+
+	for (i = 0; i < ARRAY_SIZE(known_controls); i++) {
+		if (strcmp(name, known_controls[i].name) == 0)
+			return &known_controls[i];
+	}
+
+	return NULL;
+}
