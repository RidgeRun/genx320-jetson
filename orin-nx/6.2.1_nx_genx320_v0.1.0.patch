+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+
+if [[ $# -eq 0 ]]; then
+	echo "Usage: lint-kconfig <Kconfig file> [...]" >&2
+	exit 1
+fi
+
+# checkpatch catches a subset of Kconfig style issues.
+for file in "$@"; do
+	echo "[lint-kconfig] $file"
+	"$SCRIPT_DIR/checkpatch-driver" -f "$file"
+done
diff --git a/scripts/driver-dev-tools/bin/sync-from-kernel.sh b/scripts/driver-dev-tools/bin/sync-from-kernel.sh
new file mode 100755
index 000000000..474858afc
--- /dev/null
+++ b/scripts/driver-dev-tools/bin/sync-from-kernel.sh
@@ -0,0 +1,34 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+BUNDLE_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
+KERNEL_ROOT=${1:-}
+
+if [[ -z "$KERNEL_ROOT" ]]; then
+	echo "Usage: $0 /path/to/linux" >&2
+	exit 1
+fi
+
+if [[ ! -d "$KERNEL_ROOT/scripts" ]]; then
+	echo "invalid kernel tree: $KERNEL_ROOT" >&2
+	exit 1
+fi
+
+cp "$KERNEL_ROOT/scripts/checkpatch.pl" "$BUNDLE_ROOT/tools/linux/"
