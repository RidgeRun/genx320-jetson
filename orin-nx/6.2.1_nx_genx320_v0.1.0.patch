+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+
+if [[ $# -eq 0 ]]; then
+	echo "Usage: lint-all <path> [path ...]" >&2
+	exit 1
+fi
+
+status=0
+
+mapfile -t c_files < <(find "$@" -type f \( -name '*.c' -o -name '*.h' \) 2>/dev/null)
+mapfile -t dt_files < <(find "$@" -type f \( -name '*.dts' -o -name '*.dtsi' \) 2>/dev/null)
+mapfile -t kconfig_files < <(find "$@" -type f \( -name 'Kconfig' -o -name 'Kconfig.*' \) 2>/dev/null)
+
+if [[ ${#c_files[@]} -gt 0 ]]; then
+	"$SCRIPT_DIR/lint-c" "${c_files[@]}" || status=1
+fi
+if [[ ${#dt_files[@]} -gt 0 ]]; then
+	"$SCRIPT_DIR/lint-dt" "${dt_files[@]}" || status=1
+fi
+if [[ ${#kconfig_files[@]} -gt 0 ]]; then
+	"$SCRIPT_DIR/lint-kconfig" "${kconfig_files[@]}" || status=1
+fi
+
+exit "$status"
