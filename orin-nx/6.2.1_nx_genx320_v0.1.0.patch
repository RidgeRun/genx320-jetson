diff --git a/nvidia-oot/drivers/media/i2c/genx320.c b/nvidia-oot/drivers/media/i2c/genx320.c
new file mode 100644
index 000000000..c2895c590
--- /dev/null
+++ b/nvidia-oot/drivers/media/i2c/genx320.c
@@ -0,0 +1,1451 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * genx320.c - genx320 sensor driver
+ *
+ * Copyright (c) 2026 RidgeRun,LLC. All rights reserved.
+ */
+
+#include <nvidia/conftest.h>
+
+#include <linux/slab.h>
+#include <linux/uaccess.h>
+#include <linux/gpio.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/seq_file.h>
+#include <linux/of.h>
+#include <linux/of_device.h>
+#include <linux/of_gpio.h>
+#include <linux/string.h>
+#include <linux/version.h>
+
+#include <media/tegra_v4l2_camera.h>
+#include <media/tegracam_core.h>
+#include "genx320.h"
+#include "genx320_mode_tbls.h"
+#include "genx320_regs.h"
+#define CREATE_TRACE_POINTS
+#include <trace/events/genx320.h>
+
+#define GENX320_DEFAULT_RSTN_DELAY_MS 55
+#define GENX320_BOOT_POLL_SLEEP_MS 5
+#define GENX320_BOOT_POLL_RETRIES 20
+#define GENX320_ROI_MASTER_POLL_RETRIES 50
+#define GENX320_ERC_DROP_THRESHOLD 512U
+
+static const struct of_device_id genx320_of_match[] = {
+	{
+		.compatible = "prophesee,genx320",
+	},
+	{
+		.compatible = "psee,genx320",
+	},
+	{},
+};
+MODULE_DEVICE_TABLE(of, genx320_of_match);
+
+static const struct regmap_config sensor_regmap_config = {
+	.reg_bits = 16,
+	.val_bits = 32,
+	.cache_type = REGCACHE_NONE,
+	.use_single_read = true,
+	.use_single_write = true,
+	.reg_format_endian = REGMAP_ENDIAN_BIG,
+	.val_format_endian = REGMAP_ENDIAN_BIG,
+};
+
+static int test_mode;
+module_param(test_mode, int, 0644);
+
+static int debug_status_on_stream = 1;
+module_param(debug_status_on_stream, int, 0644);
+
+static int debug_status_interval_ms;
+module_param(debug_status_interval_ms, int, 0644);
+
+static u32 genx320_evt_format_to_reg(const struct genx320 *priv);
+static void genx320_init_transport_defaults(struct genx320 *priv);
+static int genx320_parse_transport_config_dt(struct device *dev,
+					     struct genx320 *priv);
+static void genx320_sync_transport_frmfmt(struct genx320 *priv);
+static int genx320_apply_roi(struct genx320 *priv);
+static int genx320_apply_pixel_array(struct genx320 *priv);
+static int genx320_log_status(struct tegracam_device *tc_dev);
+static void genx320_status_workfn(struct work_struct *work);
+
+static int genx320_read_reg32(struct camera_common_data *s_data, u16 addr,
+			      u32 *val)
+{
+	u32 reg_val = 0;
+	int err;
+
+	err = regmap_read(s_data->regmap, addr, &reg_val);
+	if (err)
+		return err;
+
+	*val = reg_val;
+
+	return 0;
+}
+
+static int genx320_write_reg32(struct camera_common_data *s_data, u16 addr,
+			       u32 val)
+{
+	dev_dbg(s_data->dev, "register write 0x%08X: 0x%08X", addr, val);
+	return regmap_write(s_data->regmap, addr, val);
+}
+
+static int genx320_update_reg32(struct camera_common_data *s_data, u16 addr,
+				u32 mask, u32 val)
+{
+	u32 cur = 0;
+	int err;
+
+	err = genx320_read_reg32(s_data, addr, &cur);
+	if (err)
+		return err;
+
+	return genx320_write_reg32(s_data, addr, (cur & ~mask) | (val & mask));
+}
+
+static int genx320_wait_roi_master(struct genx320 *priv, u32 timeout_polls)
+{
+	struct device *dev = priv->s_data->dev;
+	u32 val = 0;
+	u32 busy = 1;
+	u32 done = 0;
+	u32 busy_reads = 0;
+	u32 done_reads = 0;
+	int err = 0;
+
+	if (!timeout_polls)
+		timeout_polls = GENX320_ROI_MASTER_POLL_RETRIES;
+
+	while (busy && busy_reads < timeout_polls) {
+		err = genx320_read_reg32(priv->s_data,
+					 GENX320_ROI_MASTER_CTRL_ADDR, &val);
+		if (err)
+			return err;
+
+		busy = !!(val & GENX320_ROI_MASTER_BUSY_MASK);
+		busy_reads++;
+	}
+
+	if (busy) {
+		dev_err(dev,
+			"%s: timeout waiting master_busy clear (polls=%u last=0x%08x)\n",
+			__func__, busy_reads, val);
+		return -ETIMEDOUT;
+	}
+
+	while (!done && done_reads < timeout_polls) {
+		err = genx320_read_reg32(priv->s_data,
+					 GENX320_ROI_MASTER_CTRL_ADDR, &val);
+		if (err)
+			return err;
+
+		done = !!(val & GENX320_ROI_MASTER_DONE_MASK);
+		done_reads++;
+	}
+
+	if (!done) {
+		dev_err(dev,
+			"%s: timeout waiting master_done set (polls=%u last=0x%08x)\n",
+			__func__, done_reads, val);
+		return -ETIMEDOUT;
+	}
+
+	dev_dbg(dev,
+		"%s: roi master done (busy polls=%u done polls=%u last=0x%08x)\n",
+		__func__, busy_reads, done_reads, val);
+
+	return 0;
+}
+
+static int genx320_write_table(struct genx320 *priv,
+			       const struct genx320_reg table[])
+{
+	u32 i;
+	int err;
+
+	for (i = 0;; i++) {
+		u32 cur = 0;
+		u32 next = 0;
+
+		if (table[i].addr == GENX320_TABLE_END)
+			break;
+
+		if (table[i].addr == GENX320_TABLE_WAIT_MS) {
+			msleep(table[i].val);
+			continue;
+		}
+
+		if (table[i].addr == GENX320_TABLE_WAIT_ROI_MASTER) {
+			err = genx320_wait_roi_master(priv, table[i].val);
+			if (err)
+				return err;
+			continue;
+		}
+
+		err = genx320_read_reg32(priv->s_data, table[i].addr, &cur);
+		if (err) {
+			dev_err(priv->s_data->dev,
+				"%s: i2c read failed @0x%04x\n", __func__,
+				table[i].addr);
+			return err;
+		}
+
+		next = (cur & ~table[i].mask) | (table[i].val & table[i].mask);
+		err = genx320_write_reg32(priv->s_data, table[i].addr, next);
+		if (err) {
+			dev_err(priv->s_data->dev,
+				"%s: i2c write failed @0x%04x mask=0x%08x val=0x%08x\n",
+				__func__, table[i].addr, table[i].mask,
+				table[i].val);
+			return err;
+		}
+	}
+
+	return 0;
+}
+
+static u32 genx320_roi_window_to_reg(u32 start, u32 size)
+{
+	u32 end = start + size;
+
+	return ((start << GENX320_ROI_WIN_START_SHIFT) &
+		GENX320_ROI_WIN_START_MASK) |
+	       ((end << GENX320_ROI_WIN_END_SHIFT) & GENX320_ROI_WIN_END_MASK);
+}
+
+static int genx320_write_roi_window(struct genx320 *priv,
+				    const struct genx320_roi *roi, u32 index)
+{
+	u16 xaddr = GENX320_ROI_WIN_ARRAY_ADDR + (8 * index);
+	u16 yaddr = xaddr + 4;
+	int err;
+
+	err = genx320_write_reg32(priv->s_data, xaddr,
+				  genx320_roi_window_to_reg(roi->x,
+							    roi->width));
+	if (err)
+		return err;
+
+	return genx320_write_reg32(priv->s_data, yaddr,
+				   genx320_roi_window_to_reg(roi->y,
+							     roi->height));
+}
+
+static int genx320_run_roi_master(struct genx320 *priv, u32 n, bool roni)
+{
+	u32 master_ctrl_val;
+	int err;
+
+	err = genx320_update_reg32(
+		priv->s_data, GENX320_ROI_CTRL_ADDR,
+		GENX320_ROI_CTRL_PX_ROI_HALT_PROGRAMMING_MASK, 0);
+	if (err)
+		return err;
+
+	master_ctrl_val = GENX320_ROI_MASTER_EN_MASK |
+			  GENX320_ROI_MASTER_RUN_MASK |
+			  (roni ? GENX320_ROI_MASTER_MODE_MASK : 0) |
+			  ((n << GENX320_ROI_MASTER_WIN_NB_SHIFT) &
+			   GENX320_ROI_MASTER_WIN_NB_MASK);
+	err = genx320_update_reg32(priv->s_data, GENX320_ROI_MASTER_CTRL_ADDR,
+				   GENX320_ROI_MASTER_EN_MASK |
+					   GENX320_ROI_MASTER_RUN_MASK |
+					   GENX320_ROI_MASTER_MODE_MASK |
+					   GENX320_ROI_MASTER_WIN_NB_MASK,
+				   master_ctrl_val);
+	if (err)
+		return err;
+
+	return genx320_wait_roi_master(priv, 100);
+}
+
+int genx320_apply_roi_config(struct genx320 *priv,
+			     const struct genx320_roi_set *set, bool roni)
+{
+	static const struct genx320_roi full_frame_roi = {
+		.x = 0,
+		.y = 0,
+		.width = GENX320_PIXEL_ARRAY_WIDTH,
+		.height = GENX320_PIXEL_ARRAY_HEIGHT,
+	};
+	u32 i;
+	int err;
+
+	if (!priv->s_data)
+		return -EINVAL;
+
+	if (!priv->s_data->power || priv->s_data->power->state != SWITCH_ON)
+		return 0;
+
+	if (!set || !set->n) {
+		err = genx320_write_roi_window(priv, &full_frame_roi, 0);
+		if (err)
+			return err;
+
+		return genx320_run_roi_master(priv, 1, false);
+	}
+
+	for (i = 0; i < set->n; i++) {
+		err = genx320_write_roi_window(priv, &set->rois[i], i);
+		if (err)
+			return err;
+	}
+
+	return genx320_run_roi_master(priv, set->n, roni);
+}
+
+static int genx320_apply_roi(struct genx320 *priv)
+{
+	const struct genx320_roi_set *set = NULL;
+	bool roni = false;
+
+	if (priv->roi_set_ctrl)
+		set = priv->roi_set_ctrl->p_cur.p_const;
+
+	if (priv->roi_roni_ctrl)
+		roni = !!priv->roi_roni_ctrl->val;
+
+	return genx320_apply_roi_config(priv, set, roni);
+}
+
+static int genx320_set_td_shadow_trigger(struct genx320 *priv, bool enable)
+{
+	return genx320_update_reg32(
+		priv->s_data, GENX320_ROI_CTRL_ADDR,
+		GENX320_ROI_CTRL_TD_SHADOW_TRIGGER_MASK,
+		enable ? GENX320_ROI_CTRL_TD_SHADOW_TRIGGER_MASK : 0);
+}
+
+int genx320_apply_pixel_array_config(struct genx320 *priv,
+				     const struct genx320_pixel_grid *grid)
+{
+	u32 y;
+	u32 x;
+	int err;
+
+	if (!priv || !priv->s_data || !grid)
+		return -EINVAL;
+
+	if (grid->width != GENX320_PIXEL_ARRAY_WIDTH ||
+	    grid->height != GENX320_PIXEL_ARRAY_HEIGHT)
+		return -EINVAL;
+
+	if (!priv->s_data->power || priv->s_data->power->state != SWITCH_ON)
+		return 0;
+
+	err = genx320_update_reg32(
+		priv->s_data, GENX320_ROI_CTRL_ADDR,
+		GENX320_ROI_CTRL_ROI_TD_EN_MASK |
+			GENX320_ROI_CTRL_TD_SHADOW_TRIGGER_MASK |
+			GENX320_ROI_CTRL_PX_IPHOTO_EN_MASK |
+			GENX320_ROI_CTRL_PX_SW_RSTN_MASK |
+			GENX320_ROI_CTRL_PX_ROI_HALT_PROGRAMMING_MASK,
+		GENX320_ROI_CTRL_ROI_TD_EN_MASK |
+			GENX320_ROI_CTRL_PX_SW_RSTN_MASK);
+	if (err)
+		return err;
+
+	/* Iterate over each row */
+	for (y = 0; y < grid->height; y++) {
+		u32 row_sel = y / 32;
+		u32 row_mask = BIT(y % 32);
+
+		err = genx320_write_reg32(
+			priv->s_data,
+			GENX320_TD_ROI_Y_ARRAY_ADDR + (4 * row_sel), row_mask);
+		if (err)
+			return err;
+
+		/* Iterate over each column composed of 32bits vectors */
+		for (x = 0; x < GENX320_PIXEL_ARRAY_WORDS; x++) {
+			err = genx320_write_reg32(priv->s_data,
+						  GENX320_TD_ROI_X_ARRAY_ADDR +
+							  (4 * x),
+						  ~grid->rows[y].vectors[x]);
+			if (err)
+				return err;
+		}
+
+		/* Apply configuration by triggering D-latches toggling */
+		err = genx320_set_td_shadow_trigger(priv, false);
+		if (err)
+			return err;
+
+		err = genx320_set_td_shadow_trigger(priv, true);
+		if (err)
+			return err;
+
+		err = genx320_write_reg32(
+			priv->s_data,
+			GENX320_TD_ROI_Y_ARRAY_ADDR + (4 * row_sel), 0);
+		if (err)
+			return err;
+
+		err = genx320_set_td_shadow_trigger(priv, false);
+		if (err)
+			return err;
+
+		err = genx320_set_td_shadow_trigger(priv, true);
+		if (err)
+			return err;
+	}
+
+	return genx320_set_td_shadow_trigger(priv, false);
+}
+
+static int genx320_apply_pixel_array(struct genx320 *priv)
+{
+	const struct genx320_pixel_grid *grid = NULL;
+
+	if (priv->roi_pixel_ctrl)
+		grid = priv->roi_pixel_ctrl->p_cur.p_const;
+
+	if (!grid)
+		return -EINVAL;
+
+	return genx320_apply_pixel_array_config(priv, grid);
+}
+
+static u32 genx320_erc_rate_to_event_count(s64 rate)
+{
+	return div_u64((u64)rate * GENX320_ERC_REF_PERIOD_DEFAULT, 1000000ULL);
+}
+
+int genx320_set_erc_event_rate(struct genx320 *priv, s64 rate)
+{
+	u32 event_count;
+	int err;
+
+	if (!priv || !priv->s_data)
+		return -EINVAL;
+
+	if (rate < 0)
+		return -ERANGE;
+
+	event_count = genx320_erc_rate_to_event_count(rate);
+	if (event_count > GENX320_ERC_TD_EVENT_COUNT_MAX)
+		return -ERANGE;
+
+	if (!priv->s_data->power || priv->s_data->power->state != SWITCH_ON)
+		return 0;
+
+	err = genx320_write_reg32(priv->s_data,
+				  GENX320_ERC_TD_TARGET_EVENT_COUNT_ADDR,
+				  event_count);
+	if (err)
+		return err;
+
+	return 0;
+}
+
+int genx320_set_erc_enable(struct genx320 *priv, bool en)
+{
+	u32 val;
+	int err;
+
+	if (!priv || !priv->s_data)
+		return -EINVAL;
+
+	if (!priv->s_data->power || priv->s_data->power->state != SWITCH_ON)
+		return 0;
+
+	err = genx320_update_reg32(
+		priv->s_data, GENX320_ERC_AHVT_DROPPING_CTRL_ADDR,
+		GENX320_ERC_AHVT_DROPPING_CTRL_T_DROPPING_EN_MASK,
+		en ? GENX320_ERC_AHVT_DROPPING_CTRL_T_DROPPING_EN_MASK : 0);
+	if (err || !en)
+		return err;
+
+	// First force hold mode to flush ERC in case it is processing an event period
+	err = genx320_update_reg32(
+		priv->s_data, GENX320_ERC_PIPELINE_CTRL_ADDR,
+		GENX320_ERC_PIPELINE_CTRL_ENABLE_MASK |
+			GENX320_ERC_PIPELINE_CTRL_DROP_NBACKPRESSURE_MASK |
+			GENX320_ERC_PIPELINE_CTRL_BYPASS_MASK,
+		0);
+	if (err)
+		return err;
+
+	// Switch to bypass mode while setting configuration
+	err = genx320_update_reg32(
+		priv->s_data, GENX320_ERC_PIPELINE_CTRL_ADDR,
+		GENX320_ERC_PIPELINE_CTRL_ENABLE_MASK |
+			GENX320_ERC_PIPELINE_CTRL_DROP_NBACKPRESSURE_MASK |
+			GENX320_ERC_PIPELINE_CTRL_BYPASS_MASK,
+		GENX320_ERC_PIPELINE_CTRL_ENABLE_MASK |
+			GENX320_ERC_PIPELINE_CTRL_BYPASS_MASK);
+	if (err)
+		return err;
+
+	// SRAM dfifo powerup
+	err = genx320_update_reg32(priv->s_data, GENX320_SRAM_INITN_ADDR,
+				   GENX320_SRAM_INITN_ERC_DL_MASK,
+				   GENX320_SRAM_INITN_ERC_DL_MASK);
+	if (err)
+		return err;
+
+	err = genx320_update_reg32(priv->s_data, GENX320_SRAM_PD1_ADDR,
+				   GENX320_SRAM_PD1_ERC_DL_MASK, 0);
+	if (err)
+		return err;
+
+	// set evt rate
+	err = genx320_update_reg32(priv->s_data,
+				   GENX320_ERC_DELAY_FIFO_FLUSH_BYPASS_ADDR,
+				   GENX320_ERC_DELAY_FIFO_FLUSH_BYPASS_EN_MASK,
+				   0);
+	if (err)
+		return err;
+
+	err = genx320_update_reg32(
+		priv->s_data, GENX320_ERC_REF_PERIOD_FLAVOR_ADDR,
+		GENX320_ERC_REF_PERIOD_FLAVOR_REFERENCE_PERIOD_MASK |
+			GENX320_ERC_REF_PERIOD_FLAVOR_AVG_DROP_RATE_DELAYED_MASK,
+		GENX320_ERC_REF_PERIOD_DEFAULT |
+			GENX320_ERC_REF_PERIOD_FLAVOR_AVG_DROP_RATE_DELAYED_MASK);
+	if (err)
+		return err;
+
+	err = genx320_update_reg32(
+		priv->s_data, GENX320_ERC_MONITORING_EVENT_CTRL_ADDR,
+		GENX320_ERC_MONITORING_EVENT_CTRL_AVG_DROP_RATE_EN_MASK |
+			GENX320_ERC_MONITORING_EVENT_CTRL_IN_TD_CNT_EN_MASK |
+			GENX320_ERC_MONITORING_EVENT_CTRL_ERC_TD_EVT_CNT_EN_MASK,
+		GENX320_ERC_MONITORING_EVENT_CTRL_AVG_DROP_RATE_EN_MASK |
+			GENX320_ERC_MONITORING_EVENT_CTRL_IN_TD_CNT_EN_MASK |
+			GENX320_ERC_MONITORING_EVENT_CTRL_ERC_TD_EVT_CNT_EN_MASK);
+	if (err)
+		return err;
+
+	err = genx320_read_reg32(priv->s_data,
+				 GENX320_ERC_AHVT_DROPPING_CTRL_ADDR, &val);
+	if (err)
+		return err;
+
+	if (!(val & GENX320_ERC_AHVT_DROPPING_CTRL_STATUS_MASK))
+		return -EIO;
+
+	err = genx320_update_reg32(
+		priv->s_data, GENX320_ERC_AHVT_DROPPING_CTRL_ADDR,
+		GENX320_ERC_AHVT_DROPPING_CTRL_T_DROPPING_EN_MASK |
+			GENX320_ERC_AHVT_DROPPING_CTRL_DROP_ALL_TD_WHEN_DROP_GEQ_MASK,
+		GENX320_ERC_AHVT_DROPPING_CTRL_T_DROPPING_EN_MASK |
+			((GENX320_ERC_DROP_THRESHOLD
+			  << GENX320_ERC_AHVT_DROPPING_CTRL_DROP_ALL_TD_WHEN_DROP_GEQ_SHIFT) &
+			 GENX320_ERC_AHVT_DROPPING_CTRL_DROP_ALL_TD_WHEN_DROP_GEQ_MASK));
+	if (err)
+		return err;
+
+	// Do not reset tdrop counter between event periods, since it mostly
+	// preserves events at the beginning of the lines.
+	err = genx320_update_reg32(priv->s_data,
+				   GENX320_ERC_RESET_TDROP_COUNTER_ADDR,
+				   GENX320_ERC_RESET_TDROP_COUNTER_EN_MASK, 0);
+	if (err)
+		return err;
+
+	// disable ERC bypass
+	return genx320_update_reg32(priv->s_data,
+				    GENX320_ERC_PIPELINE_CTRL_ADDR,
+				    GENX320_ERC_PIPELINE_CTRL_BYPASS_MASK, 0);
+}
+
+int genx320_write_bias_reg(struct genx320 *priv, u16 addr, u8 val)
+{
+	if (!priv || !priv->s_data)
+		return -EINVAL;
+
+	if (!priv->s_data->power || priv->s_data->power->state != SWITCH_ON)
+		return 0;
+
+	return genx320_update_reg32(
+		priv->s_data, addr,
+		GENX320_BIAS_CTL_MASK | GENX320_BIAS_SINGLE_MASK,
+		((u32)val & GENX320_BIAS_CTL_MASK) | GENX320_BIAS_SINGLE_MASK);
+}
+
+static int genx320_hw_init(struct genx320 *priv)
+{
+	struct genx320_reg runtime_cfg[] = {
+		{
+			GENX320_EDF_CONTROL_ADDR,
+			GENX320_EDF_CONTROL_MASK,
+			genx320_evt_format_to_reg(priv),
+		},
+		{ GENX320_TABLE_END, 0x00000000, 0x00000000 },
+	};
+	int err;
+
+	err = genx320_write_table(priv, mode_table[GENX320_MODE_DEFAULT]);
+	if (err)
+		return err;
+
+	/* Keep only runtime-configurable fields here. */
+	err = genx320_write_table(priv, runtime_cfg);
+	if (err)
+		return err;
+
+	err = genx320_apply_transport_mode(priv);
+	if (err)
+		return err;
+
+	err = genx320_apply_bias_controls(priv);
+	if (err)
+		return err;
+
+	err = genx320_apply_erc_controls(priv);
+	if (err)
+		return err;
+
+	err = genx320_apply_roi(priv);
+	if (err)
+		return err;
+
+	return genx320_apply_pixel_array(priv);
+}
+
+static u32 genx320_evt_format_to_reg(const struct genx320 *priv)
+{
+	switch (priv->evt_format) {
+	case GENX320_EVT_FORMAT_EVT2:
+		return 0;
+	case GENX320_EVT_FORMAT_EVT3:
+		return 1;
+	case GENX320_EVT_FORMAT_EVT21:
+	default:
+		return 2;
+	}
+}
+
+int genx320_apply_evt_format(struct genx320 *priv)
+{
+	return genx320_write_reg32(priv->s_data, GENX320_EDF_CONTROL_ADDR,
+				   genx320_evt_format_to_reg(priv));
+}
+
+int genx320_apply_transport_mode(struct genx320 *priv)
+{
+	struct genx320_reg transport_cfg[] = {
+		{
+			GENX320_MIPI_CSI_CTRL_ADDR,
+			((u32)GENX320_MIPI_PKT_SIZE_MASK
+			 << GENX320_MIPI_PKT_SIZE_SHIFT),
+			0,
+		},
+		{
+			GENX320_MIPI_CSI_FRAME_CTRL_ADDR,
+			GENX320_MIPI_FRAME_CTRL_PKT_TIMEOUT_EN_MASK |
+				GENX320_MIPI_FRAME_CTRL_PKT_FIX_RATE_EN_MASK |
+				GENX320_MIPI_FRAME_CTRL_PKT_FIX_SIZE_EN_MASK |
+				GENX320_MIPI_FRAME_CTRL_FRAME_FIX_RATE_EN_MASK |
+				GENX320_MIPI_FRAME_CTRL_FRAME_FIX_SIZE_EN_MASK |
+				GENX320_MIPI_FRAME_CTRL_FIX_RATE_EMPTY_PKT_MASK,
+			0,
+		},
+		{
+			GENX320_MIPI_CSI_FRAME_CFG_ADDR,
+			GENX320_MIPI_FRAME_CFG_SIZE_MASK,
+			0,
+		},
+		{
+			GENX320_EDF_OUTPUT_INTERFACE_CTRL_ADDR,
+			GENX320_EDF_SOF_TIMEOUT_MASK,
+			GENX320_TRANSPORT_WINDOW_US_DEFAULT,
+		},
+		{ GENX320_TABLE_END, 0x00000000, 0x00000000 },
+	};
+
+	if (!priv || !priv->s_data)
+		return -EINVAL;
+
+	transport_cfg[GENX320_TRANSPORT_CFG_CSI_CTRL].val =
+		((u32)priv->transport_packet_size
+		 << GENX320_MIPI_PKT_SIZE_SHIFT);
+
+	switch (priv->transport_mode) {
+	case GENX320_TRANSPORT_MODE_VARIABLE:
+		transport_cfg[GENX320_TRANSPORT_CFG_EDF_TIMEOUT].val =
+			priv->transport_window_us;
+		break;
+	case GENX320_TRANSPORT_MODE_FIXED_FRAME_SIZE:
+		transport_cfg[GENX320_TRANSPORT_CFG_FRAME_CTRL].val =
+			GENX320_MIPI_FRAME_CTRL_PKT_FIX_SIZE_EN_MASK |
+			GENX320_MIPI_FRAME_CTRL_FRAME_FIX_SIZE_EN_MASK;
+		transport_cfg[GENX320_TRANSPORT_CFG_FRAME_SIZE].val =
+			priv->transport_frame_size
+			<< GENX320_MIPI_FRAME_CFG_SIZE_SHIFT;
+		transport_cfg[GENX320_TRANSPORT_CFG_EDF_TIMEOUT].val =
+			GENX320_EDF_SOF_TIMEOUT_FIXED_FRAME_SIZE;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	if (!priv->s_data->power || priv->s_data->power->state != SWITCH_ON)
+		return 0;
+
+	return genx320_write_table(priv, transport_cfg);
+}
+
+static void genx320_init_transport_defaults(struct genx320 *priv)
+{
+	if (!priv)
+		return;
+
+	priv->transport_mode = GENX320_TRANSPORT_MODE_VARIABLE;
+	priv->transport_packet_size = GENX320_MIPI_PKT_SIZE_DEFAULT;
+	priv->transport_frame_size = GENX320_FIXED_FRAME_SIZE_DEFAULT;
+	priv->transport_window_us = GENX320_TRANSPORT_WINDOW_US_DEFAULT;
+}
+
+static void genx320_sync_transport_frmfmt(struct genx320 *priv)
+{
+	if (!priv)
+		return;
+
+	priv->frmfmt[0].size.width = priv->transport_packet_size;
+	priv->frmfmt[0].size.height = priv->transport_frame_size;
+}
+/**
+ * genx320_check_boot() - Check the boot magic
+ * @genx320: pointer to the genx320 device
+ *
+ * There is a misc register switching to a magic value at the end of sensor boot process
+ * It should be covered by the wait time given by Prophesee, thus this is just a sanity check
+ *
+ * Reference rpi implementation: genx320.c::genx320_check_boot()
+ */
+static int genx320_check_boot(struct genx320 *priv)
+{
+	struct device *dev = priv->s_data->dev;
+	u32 val = 0;
+	int err = 0;
+	int i;
+
+	for (i = 0; i < GENX320_BOOT_POLL_RETRIES; i++) {
+		err = genx320_read_reg32(priv->s_data, GENX320_MBX_MISC_ADDR,
+					 &val);
+		if (!err && val == GENX320_BOOT_MAGIC)
+			return 0;
+
+		msleep_interruptible(GENX320_BOOT_POLL_SLEEP_MS);
+	}
+
+	if (err) {
+		dev_err(dev, "%s: failed to read boot magic (%d)\n", __func__,
+			err);
+		return err;
+	}
+
+	dev_err(dev, "%s: unexpected boot magic 0x%08x expected 0x%08x\n",
+		__func__, val, GENX320_BOOT_MAGIC);
+
+	return -ETIMEDOUT;
+}
+static int genx320_power_on(struct camera_common_data *s_data)
+{
+	int err = 0;
+	struct genx320 *priv = (struct genx320 *)s_data->priv;
+	struct camera_common_power_rail *pw = s_data->power;
+	struct camera_common_pdata *pdata = s_data->pdata;
+	struct device *dev = s_data->dev;
+
+	dev_dbg(dev, "%s: power on\n", __func__);
+	if (pdata && pdata->power_on) {
+		err = pdata->power_on(pw);
+		if (err) {
+			dev_err(dev, "%s failed.\n", __func__);
+			goto done;
+		}
+		goto check_boot;
+	}
+
+	/* Sequence aligned with rpi genx320.c::genx320_power_on() */
+
+	/* Drive PWDN low before sensor bring-up. */
+	if (pw->reset_gpio) {
+		if (gpiod_cansleep(gpio_to_desc(pw->reset_gpio)))
+			gpio_set_value_cansleep(pw->reset_gpio, 0);
+		else
+			gpio_set_value(pw->reset_gpio, 0);
+	}
+
+	/* Deassert PWDN to let the sensor boot. */
+	if (pw->reset_gpio) {
+		if (gpiod_cansleep(gpio_to_desc(pw->reset_gpio)))
+			gpio_set_value_cansleep(pw->reset_gpio, 1);
+		else
+			gpio_set_value(pw->reset_gpio, 1);
+
+		/* Tstart = 15ms (min) */
+		/* but CCAM5 introduces 48ms +/-15% delay */
+		msleep_interruptible(15 + priv->rstn_delay_ms);
+	}
+
+check_boot:
+	err = genx320_check_boot(priv);
+	if (err) {
+		dev_err(dev, "%s: sensor boot check failed\n", __func__);
+		/* Keep sensor in PWDN on boot failure. */
+		if (pw->reset_gpio) {
+			if (gpiod_cansleep(gpio_to_desc(pw->reset_gpio)))
+				gpio_set_value_cansleep(pw->reset_gpio, 0);
+			else
+				gpio_set_value(pw->reset_gpio, 0);
+		}
+		goto done;
+	}
+
+	pw->state = SWITCH_ON;
+done:
+	return err;
+}
+
+static int genx320_power_off(struct camera_common_data *s_data)
+{
+	int err = 0;
+	struct camera_common_power_rail *pw = s_data->power;
+	struct camera_common_pdata *pdata = s_data->pdata;
+	struct device *dev = s_data->dev;
+
+	dev_dbg(dev, "%s: power off\n", __func__);
+
+	if (pdata && pdata->power_off) {
+		err = pdata->power_off(pw);
+		if (err) {
+			dev_err(dev, "%s failed.\n", __func__);
+			goto done;
+		}
+		goto power_off_done;
+	}
+	/* Assert PWDN before power-off. */
+	usleep_range(1, 2);
+	if (pw->reset_gpio) {
+		if (gpiod_cansleep(gpio_to_desc(pw->reset_gpio)))
+			gpio_set_value_cansleep(pw->reset_gpio, 0);
+		else
+			gpio_set_value(pw->reset_gpio, 0);
+	}
+
+power_off_done:
+	pw->state = SWITCH_OFF;
+done:
+	return err;
+}
+
+static int genx320_power_get(struct tegracam_device *tc_dev)
+{
+	int err = 0;
+	struct camera_common_data *s_data = tc_dev->s_data;
+	struct camera_common_power_rail *pw = s_data->power;
+	struct camera_common_pdata *pdata = s_data->pdata;
+
+	if (!pdata) {
+		err = -EINVAL;
+		goto done;
+	}
+
+	pw->reset_gpio = pdata->reset_gpio;
+
+	pw->state = SWITCH_OFF;
+done:
+	return err;
+}
+
+static int genx320_power_put(struct tegracam_device *tc_dev)
+{
+	int err = 0;
+	struct camera_common_data *s_data = tc_dev->s_data;
+	struct camera_common_power_rail *pw = s_data->power;
+
+	if (unlikely(!pw))
+		err = -EFAULT;
+
+	return err;
+}
+
+static struct camera_common_pdata *
+genx320_parse_dt(struct tegracam_device *tc_dev)
+{
+	struct device *dev = &tc_dev->client->dev;
+	struct device_node *np = dev->of_node;
+	struct camera_common_pdata *board_priv_pdata = NULL;
+	const struct of_device_id *match = NULL;
+	struct camera_common_pdata *ret = NULL;
+	int gpio = 0;
+
+	if (!np)
+		goto done;
+
+	match = of_match_device(genx320_of_match, dev);
+	if (!match) {
+		dev_err(dev, "Failed to find matching dt id\n");
+		goto done;
+	}
+
+	board_priv_pdata =
+		devm_kzalloc(dev, sizeof(*board_priv_pdata), GFP_KERNEL);
+	if (!board_priv_pdata)
+		goto done;
+
+	/* Reuse camera-common reset-gpios binding for the board PWDN pin. */
+	gpio = of_get_named_gpio(np, "reset-gpios", 0);
+	if (gpio < 0) {
+		if (gpio == -EPROBE_DEFER)
+			ret = ERR_PTR(-EPROBE_DEFER);
+		dev_err(dev, "reset-gpios not found %d\n", gpio);
+		goto error;
+	}
+	board_priv_pdata->reset_gpio = (unsigned int)gpio;
+	ret = board_priv_pdata;
+	goto done;
+
+error:
+	devm_kfree(dev, board_priv_pdata);
+done:
+	return ret;
+}
+
+static int genx320_parse_transport_config_dt(struct device *dev,
+					     struct genx320 *priv)
+{
+	const char *mode_name = NULL;
+	u32 value = 0;
+	int err;
+
+	if (!dev || !priv)
+		return -EINVAL;
+
+	/*
+	 * Accepted DT transport properties:
+	 * psee,transport-mode        = "variable" | "fixed-frame-size"
+	 * psee,transport-packet-size = 4..8192 bytes, multiple of 4
+	 * psee,transport-frame-size  = 1..65535 packets/frame
+	 * psee,transport-window-us   = 16..65520 us, multiple of 16
+	 *                             used only with "variable"
+	 */
+	err = of_property_read_string(dev->of_node, "psee,transport-mode",
+				      &mode_name);
+	if (!err) {
+		if (!strcmp(mode_name, "variable")) {
+			priv->transport_mode = GENX320_TRANSPORT_MODE_VARIABLE;
+		} else if (!strcmp(mode_name, "fixed-frame-size")) {
+			priv->transport_mode =
+				GENX320_TRANSPORT_MODE_FIXED_FRAME_SIZE;
+		} else {
+			dev_warn(
+				dev,
+				"unsupported psee,transport-mode \"%s\", valid values are \"variable\" and \"fixed-frame-size\"; using default \"variable\"\n",
+				mode_name);
+		}
+	}
+
+	err = of_property_read_u32(dev->of_node, "psee,transport-packet-size",
+				   &value);
+	if (!err) {
+		if (value < GENX320_MIPI_PKT_SIZE_MIN ||
+		    value > GENX320_MIPI_PKT_SIZE_MAX ||
+		    value % GENX320_MIPI_PKT_SIZE_ALIGN) {
+			dev_warn(
+				dev,
+				"invalid psee,transport-packet-size %u, valid range is %u..%u bytes in multiples of %u; using default %u\n",
+				value, GENX320_MIPI_PKT_SIZE_MIN,
+				GENX320_MIPI_PKT_SIZE_MAX,
+				GENX320_MIPI_PKT_SIZE_ALIGN,
+				GENX320_MIPI_PKT_SIZE_DEFAULT);
+		} else {
+			priv->transport_packet_size = value;
+		}
+	}
+
+	err = of_property_read_u32(dev->of_node, "psee,transport-frame-size",
+				   &value);
+	if (!err) {
+		if (value < GENX320_TRANSPORT_FRAME_SIZE_MIN ||
+		    value > GENX320_TRANSPORT_FRAME_SIZE_MAX) {
+			dev_warn(
+				dev,
+				"invalid psee,transport-frame-size %u, valid range is %u..%u packets/frame; using default %u\n",
+				value, GENX320_TRANSPORT_FRAME_SIZE_MIN,
+				GENX320_TRANSPORT_FRAME_SIZE_MAX,
+				GENX320_FIXED_FRAME_SIZE_DEFAULT);
+		} else {
+			priv->transport_frame_size = value;
+		}
+	}
+
+	err = of_property_read_u32(dev->of_node, "psee,transport-window-us",
+				   &value);
+	if (!err) {
+		if (value < GENX320_TRANSPORT_WINDOW_US_MIN ||
+		    value > GENX320_TRANSPORT_WINDOW_US_MAX ||
+		    value % GENX320_TRANSPORT_WINDOW_US_ALIGN) {
+			dev_warn(
+				dev,
+				"invalid psee,transport-window-us %u, valid range is %u..%u us in multiples of %u; using default %u\n",
+				value, GENX320_TRANSPORT_WINDOW_US_MIN,
+				GENX320_TRANSPORT_WINDOW_US_MAX,
+				GENX320_TRANSPORT_WINDOW_US_ALIGN,
+				GENX320_TRANSPORT_WINDOW_US_DEFAULT);
+		} else {
+			priv->transport_window_us = value;
+		}
+	}
+
+	return 0;
+}
+
+static int genx320_set_mode(struct tegracam_device *tc_dev)
+{
+	struct genx320 *priv = (struct genx320 *)tegracam_get_privdata(tc_dev);
+	struct camera_common_data *s_data = tc_dev->s_data;
+	struct device *dev = &tc_dev->client->dev;
+	const struct of_device_id *match = NULL;
+	int err = 0;
+
+	match = of_match_device(genx320_of_match, dev);
+	if (!match) {
+		dev_err(dev, "Failed to find matching dt id\n");
+		err = -EINVAL;
+		goto done;
+	}
+
+	if (s_data->mode_prop_idx < 0) {
+		err = -EINVAL;
+		goto done;
+	}
+
+	if (s_data->mode_prop_idx != GENX320_MODE_DEFAULT) {
+		err = -EINVAL;
+		goto done;
+	}
+
+	err = genx320_hw_init(priv);
+done:
+	return err;
+}
+
+static int genx320_identify_module(struct genx320 *priv)
+{
+	struct device *dev = priv->s_data->dev;
+	u32 module_id = 0;
+	int err = 0;
+
+	err = genx320_read_reg32(priv->s_data, GENX320_SENSOR_ID_ADDR,
+				 &module_id);
+	if (err) {
+		dev_err(dev, "%s: failed to read sensor id\n", __func__);
+	} else if (module_id != GENX320_EXPECTED_SENSOR_ID) {
+		dev_err(dev, "%s: sensor id mismatch 0x%08x != 0x%08x\n",
+			__func__, module_id, GENX320_EXPECTED_SENSOR_ID);
+		err = -ENODEV;
+	}
+
+	return err;
+}
+
+static int genx320_start_streaming(struct tegracam_device *tc_dev)
+{
+	struct genx320 *priv = (struct genx320 *)tegracam_get_privdata(tc_dev);
+	int err = 0;
+
+	if (test_mode) {
+		err = genx320_write_table(
+			priv, mode_table[GENX320_MODE_TEST_PATTERN]);
+		if (err)
+			goto done;
+	}
+
+	err = genx320_write_table(priv, mode_table[GENX320_MODE_START_STREAM]);
+	if (err)
+		goto done;
+
+	trace_genx320_s_stream(tc_dev->name, 1, tc_dev->s_data->mode_prop_idx);
+	priv->status_poll_active = true;
+	if (debug_status_on_stream) {
+		int dbg_err = genx320_log_status(tc_dev);
+
+		if (dbg_err)
+			dev_warn(tc_dev->dev, "%s: log_status failed: %d\n",
+				 __func__, dbg_err);
+	}
+	if (debug_status_interval_ms > 0)
+		schedule_delayed_work(
+			&priv->status_work,
+			msecs_to_jiffies(debug_status_interval_ms));
+
+done:
+	return err;
+}
+
+static int genx320_stop_streaming(struct tegracam_device *tc_dev)
+{
+	struct camera_common_data *s_data = tc_dev->s_data;
+	struct genx320 *priv = (struct genx320 *)tegracam_get_privdata(tc_dev);
+	int err = 0;
+
+	priv->status_poll_active = false;
+	cancel_delayed_work_sync(&priv->status_work);
+
+	err = genx320_write_table(priv, mode_table[GENX320_MODE_STOP_STREAM]);
+	if (err)
+		goto done;
+
+	trace_genx320_s_stream(tc_dev->name, 0, s_data->mode_prop_idx);
+
+done:
+	return err;
+}
+
+static void genx320_status_workfn(struct work_struct *work)
+{
+	struct delayed_work *dwork = to_delayed_work(work);
+	struct genx320 *priv = container_of(dwork, struct genx320, status_work);
+	int interval_ms;
+	int err;
+
+	if (!priv || !priv->tc_dev)
+		return;
+
+	if (!priv->status_poll_active)
+		return;
+
+	err = genx320_log_status(priv->tc_dev);
+	if (err)
+		dev_warn(priv->tc_dev->dev, "%s: log_status failed: %d\n",
+			 __func__, err);
+
+	interval_ms = debug_status_interval_ms;
+	if (priv->status_poll_active && interval_ms > 0)
+		schedule_delayed_work(&priv->status_work,
+				      msecs_to_jiffies(interval_ms));
+}
+
+static int genx320_log_status(struct tegracam_device *tc_dev)
+{
+	struct genx320 *priv = (struct genx320 *)tegracam_get_privdata(tc_dev);
+	struct camera_common_data *s_data;
+	struct camera_common_power_rail *pw;
+	struct device *dev;
+	u32 val = 0;
+	u32 sof_timeout = 0;
+	u32 stat_ctrl = 0;
+	int err = 0;
+
+	if (!priv || !priv->s_data)
+		return -EINVAL;
+
+	s_data = priv->s_data;
+	pw = s_data->power;
+	dev = s_data->dev;
+
+	if (!pw || pw->state != SWITCH_ON) {
+		dev_info(dev, "Cannot report status. Sensor is powered down");
+		return 0;
+	}
+
+	dev_info(dev, "=================  START STATUS  =================");
+	dev_info(dev, "******* MIPI_CSI STATUS ********");
+
+	err = genx320_read_reg32(s_data, GENX320_MIPI_CSI_STAT_CTRL_ADDR,
+				 &stat_ctrl);
+	if (err) {
+		dev_err(dev, "%s: failed to read mipi_csi_stat_ctrl (%d)\n",
+			__func__, err);
+		return err;
+	}
+	dev_info(dev, "stat ctrl, 0x%08x ", stat_ctrl);
+	if (!(stat_ctrl & 0x1U)) {
+		dev_info(dev, "MIPI_CSI stats not enabled");
+		goto log_bias_status;
+	}
+
+	err = genx320_read_reg32(s_data, GENX320_EDF_OUTPUT_INTERFACE_CTRL_ADDR,
+				 &val);
+	if (err)
+		return err;
+	sof_timeout = (val >> 4) & 0xFFF;
+	dev_info(
+		dev,
+		"edf_output_interface_control: 0x%08x (start_of_frame_timeout=0x%x/%u)",
+		val, sof_timeout, sof_timeout);
+
+	err = genx320_read_reg32(s_data, GENX320_MIPI_CSI_STAT_FRAME_CNT_ADDR,
+				 &val);
+	if (err)
+		return err;
+	dev_info(dev, "Frame Count: %u", val);
+
+	err = genx320_read_reg32(s_data, GENX320_MIPI_CSI_STAT_BYTE_CNT_ADDR,
+				 &val);
+	if (err)
+		return err;
+	dev_info(dev, "Byte Count: %u", val);
+
+	err = genx320_read_reg32(s_data, GENX320_MIPI_CSI_STAT_PAD_CNT_ADDR,
+				 &val);
+	if (err)
+		return err;
+	dev_info(dev, "Pad Count: %u", val);
+
+	err = genx320_read_reg32(s_data, GENX320_MIPI_CSI_STAT_PKT_CNT_ADDR,
+				 &val);
+	if (err)
+		return err;
+	dev_info(dev, "Packet Count: %u", val);
+
+	err = genx320_read_reg32(s_data, GENX320_MIPI_CSI_STAT_INC_PKT_CNT_ADDR,
+				 &val);
+	if (err)
+		return err;
+	dev_info(dev, "Incomplete Packet Count: %u", val);
+
+	err = genx320_read_reg32(s_data,
+				 GENX320_MIPI_CSI_STAT_FRAME_PERIOD_ADDR, &val);
+	if (err)
+		return err;
+	dev_info(dev, "Frame Period: %u", val);
+
+log_bias_status:
+	dev_info(dev, "******* BIAS STATUS ********");
+
+	err = genx320_read_reg32(s_data, GENX320_BIAS0_FO_ADDR, &val);
+	if (err)
+		return err;
+	dev_info(dev, "bias_fo: 0x%x", val);
+
+	err = genx320_read_reg32(s_data, GENX320_BIAS0_HPF_ADDR, &val);
+	if (err)
+		return err;
+	dev_info(dev, "bias_hpf: 0x%x", val);
+
+	err = genx320_read_reg32(s_data, GENX320_BIAS0_DIFF_ON_ADDR, &val);
+	if (err)
+		return err;
+	dev_info(dev, "bias_diff_on: 0x%x", val);
+
+	err = genx320_read_reg32(s_data, GENX320_BIAS0_DIFF_ADDR, &val);
+	if (err)
+		return err;
+	dev_info(dev, "bias_diff: 0x%x", val);
+
+	err = genx320_read_reg32(s_data, GENX320_BIAS0_DIFF_OFF_ADDR, &val);
+	if (err)
+		return err;
+	dev_info(dev, "bias_diff_off: 0x%x", val);
+
+	err = genx320_read_reg32(s_data, GENX320_BIAS0_REFR_ADDR, &val);
+	if (err)
+		return err;
+	dev_info(dev, "bias_refr: 0x%x", val);
+	dev_info(dev, "==================  END STATUS  ==================");
+
+	return 0;
+}
+
+static const struct camera_common_sensor_ops genx320_common_ops = {
+	.numfrmfmts = ARRAY_SIZE(genx320_default_frmfmt),
+	.frmfmt_table = genx320_default_frmfmt,
+	.power_on = genx320_power_on,
+	.power_off = genx320_power_off,
+	.parse_dt = genx320_parse_dt,
+	.power_get = genx320_power_get,
+	.power_put = genx320_power_put,
+	.set_mode = genx320_set_mode,
+	.start_streaming = genx320_start_streaming,
+	.stop_streaming = genx320_stop_streaming,
+};
+
+static int genx320_open(struct v4l2_subdev *sd, struct v4l2_subdev_fh *fh)
+{
+	struct i2c_client *client = v4l2_get_subdevdata(sd);
+
+	dev_dbg(&client->dev, "open subdevice\n");
+
+	return 0;
+}
+
+static const struct v4l2_subdev_internal_ops genx320_subdev_internal_ops = {
+	.open = genx320_open,
+};
+
+#if defined(NV_I2C_DRIVER_STRUCT_PROBE_WITHOUT_I2C_DEVICE_ID_ARG) /* Linux 6.3 */
+static int genx320_probe(struct i2c_client *client)
+#else
+static int genx320_probe(struct i2c_client *client,
+			 const struct i2c_device_id *id)
+#endif
+{
+	struct device *dev = &client->dev;
+	struct tegracam_device *tc_dev = NULL;
+	struct genx320 *priv = NULL;
+	int err = 0;
+	bool sensor_powered = false;
+	bool tc_dev_registered = false;
+	bool v4l2_subdev_registered = false;
+
+	dev_info(dev, "probing v4l2 sensor\n");
+
+	if (!IS_ENABLED(CONFIG_OF) || !client->dev.of_node) {
+		err = -EINVAL;
+		goto done;
+	}
+
+	priv = devm_kzalloc(dev, sizeof(struct genx320), GFP_KERNEL);
+	if (!priv) {
+		err = -ENOMEM;
+		goto done;
+	}
+	INIT_DELAYED_WORK(&priv->status_work, genx320_status_workfn);
+	priv->status_poll_active = false;
+	priv->evt_format = GENX320_EVT_FORMAT_EVT21;
+	genx320_init_transport_defaults(priv);
+	priv->frmfmt[0] = genx320_default_frmfmt[0];
+	genx320_parse_transport_config_dt(dev, priv);
+	genx320_sync_transport_frmfmt(priv);
+
+	tc_dev = devm_kzalloc(dev, sizeof(struct tegracam_device), GFP_KERNEL);
+	if (!tc_dev) {
+		err = -ENOMEM;
+		goto done;
+	}
+
+	priv->i2c_client = tc_dev->client = client;
+	tc_dev->dev = dev;
+	strscpy(tc_dev->name, "genx320", sizeof(tc_dev->name));
+	tc_dev->dev_regmap_config = &sensor_regmap_config;
+	priv->common_ops = genx320_common_ops;
+	priv->common_ops.numfrmfmts = ARRAY_SIZE(priv->frmfmt);
+	priv->common_ops.frmfmt_table = priv->frmfmt;
+	tc_dev->sensor_ops = &priv->common_ops;
+	tc_dev->v4l2sd_internal_ops = &genx320_subdev_internal_ops;
+	tc_dev->tcctrl_ops = &genx320_ctrl_ops;
+
+	err = tegracam_device_register(tc_dev);
+	if (err) {
+		dev_err(dev, "tegra camera driver registration failed\n");
+		goto done;
+	}
+	tc_dev_registered = true;
+	priv->tc_dev = tc_dev;
+	priv->s_data = tc_dev->s_data;
+	priv->subdev = &tc_dev->s_data->subdev;
+	/* Keep fallback in sync with rpi genx320.c::genx320_parse_hw_config() */
+	priv->rstn_delay_ms = GENX320_DEFAULT_RSTN_DELAY_MS;
+	tegracam_set_privdata(tc_dev, (void *)priv);
+
+	if (of_property_read_u32(client->dev.of_node, "rstn-delay-ms",
+				 &priv->rstn_delay_ms))
+		dev_warn(dev, "rstn-delay-ms not found, using default %u ms\n",
+			 priv->rstn_delay_ms);
+
+	err = genx320_power_on(priv->s_data);
+	if (err) {
+		dev_err(dev, "sensor power on failed: %d\n", err);
+		goto done;
+	}
+	sensor_powered = true;
+
+	err = genx320_identify_module(priv);
+	if (err) {
+		dev_err(dev, "sensor identification failed: %d\n", err);
+		goto done;
+	}
+
+	genx320_power_off(priv->s_data);
+	sensor_powered = false;
+
+	err = tegracam_v4l2subdev_register(tc_dev, true);
+	if (err) {
+		dev_err(dev, "tegra camera subdev registration failed\n");
+		goto done;
+	}
+	v4l2_subdev_registered = true;
+
+	err = genx320_register_v4l2_controls(priv);
+	if (err) {
+		dev_err(dev, "failed to register GENX320 V4L2 controls: %d\n",
+			err);
+		goto done;
+	}
+
+	dev_info(dev, "Detected GENX320 sensor\n");
+
+done:
+	if (sensor_powered && priv && priv->s_data)
+		genx320_power_off(priv->s_data);
+	if (err && v4l2_subdev_registered && tc_dev)
+		tegracam_v4l2subdev_unregister(tc_dev);
+	if (err && tc_dev_registered && tc_dev)
+		tegracam_device_unregister(tc_dev);
+
+	return err;
+}
+
+#if defined(NV_I2C_DRIVER_STRUCT_REMOVE_RETURN_TYPE_INT) /* Linux 6.1 */
+static int genx320_remove(struct i2c_client *client)
+#else
+static void genx320_remove(struct i2c_client *client)
+#endif
+{
+	struct camera_common_data *s_data = to_camera_common_data(&client->dev);
+	struct genx320 *priv = NULL;
+#if defined(NV_I2C_DRIVER_STRUCT_REMOVE_RETURN_TYPE_INT) /* Linux 6.1 */
+	int err = 0;
+#endif
+
+	if (!s_data) {
+#if defined(NV_I2C_DRIVER_STRUCT_REMOVE_RETURN_TYPE_INT) /* Linux 6.1 */
+		err = -EINVAL;
+		goto done;
+#else
+		goto done;
+#endif
+	}
+
+	priv = (struct genx320 *)s_data->priv;
+	if (!priv || !priv->tc_dev) {
+#if defined(NV_I2C_DRIVER_STRUCT_REMOVE_RETURN_TYPE_INT) /* Linux 6.1 */
+		err = -EINVAL;
+#endif
+		goto done;
+	}
+
+	priv->status_poll_active = false;
+	cancel_delayed_work_sync(&priv->status_work);
+
+	tegracam_v4l2subdev_unregister(priv->tc_dev);
+	tegracam_device_unregister(priv->tc_dev);
+done:
+#if defined(NV_I2C_DRIVER_STRUCT_REMOVE_RETURN_TYPE_INT) /* Linux 6.1 */
+	return err;
+#else
+	return;
+#endif
+}
+
+static const struct i2c_device_id genx320_id[] = { { "genx320", 0 }, {} };
+
+MODULE_DEVICE_TABLE(i2c, genx320_id);
+
+static struct i2c_driver genx320_i2c_driver = {
+	.driver = {
+		.name = "genx320",
+		.owner = THIS_MODULE,
+		.of_match_table = of_match_ptr(genx320_of_match),
+	},
+	.probe = genx320_probe,
+	.remove = genx320_remove,
+	.id_table = genx320_id,
+};
+
+module_i2c_driver(genx320_i2c_driver);
+
+MODULE_DESCRIPTION("Media Controller driver for Prophesee GENX320");
+MODULE_AUTHOR("RidgeRun,LLC");
+MODULE_LICENSE("GPL v2");
diff --git a/nvidia-oot/drivers/media/i2c/genx320.h b/nvidia-oot/drivers/media/i2c/genx320.h
new file mode 100644
index 000000000..9c3171db8
--- /dev/null
+++ b/nvidia-oot/drivers/media/i2c/genx320.h
@@ -0,0 +1,123 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * Shared definitions for the GENX320 driver split across core and controls.
+ */
+
+#ifndef __GENX320_H__
+#define __GENX320_H__
+
+#include <linux/i2c.h>
+#include <linux/types.h>
+#include <linux/workqueue.h>
+
+#include <media/tegracam_core.h>
+
+#define GENX320_PIXEL_ARRAY_WIDTH 320
+#define GENX320_PIXEL_ARRAY_HEIGHT 320
+#define GENX320_PIXEL_ARRAY_WORDS (GENX320_PIXEL_ARRAY_WIDTH / 32)
+#define GENX320_MAX_ROI_WINDOWS 18
+#define GENX320_NUM_BIAS_CTRLS 6
+#define GENX320_NUM_FRMFMTS 1
+#define GENX320_ERC_REF_PERIOD_DEFAULT 100
+#define GENX320_ERC_TD_EVENT_COUNT_MAX 20000LL
+
+#define GENX320_CID_EVT_FORMAT (V4L2_CID_USER_BASE + 0x2003)
+#define GENX320_CID_WIDTH (V4L2_CID_USER_BASE + 0x2004)
+#define GENX320_CID_HEIGHT (V4L2_CID_USER_BASE + 0x2005)
+#define PSEE_ERC_CLASS 0x1000
+#define PSEE_CID_ERC_CTRL (V4L2_CID_USER_BASE | PSEE_ERC_CLASS)
+#define PSEE_CID_ERC_RATE (PSEE_CID_ERC_CTRL + 1)
+#define PSEE_CID_ERC_ENABLE (PSEE_CID_ERC_CTRL + 2)
+#define PSEE_BIAS_CLASS 0x3000
+#define PSEE_CID_BIAS_CTRL (V4L2_CID_USER_BASE | PSEE_BIAS_CLASS)
+#define PSEE_CMPTYPE_ROI (V4L2_CTRL_COMPOUND_TYPES + 101)
+#define PSEE_CMPTYPE_ROI_PIXEL (V4L2_CTRL_COMPOUND_TYPES + 102)
+#define PSEE_ROI_CLASS 0x4000
+#define PSEE_CID_ROI_CTRL (V4L2_CID_USER_BASE | PSEE_ROI_CLASS)
+#define PSEE_CID_ROI_RESET (PSEE_CID_ROI_CTRL + 1)
+#define PSEE_CID_ROI_WINDOW_SET (PSEE_CID_ROI_CTRL + 4)
+#define PSEE_CID_ROI_RONI (PSEE_CID_ROI_CTRL + 6)
+#define GENX320_CID_ROI_PIXEL_RESET (PSEE_CID_ROI_CTRL + 7)
+#define GENX320_CID_ROI_PIXEL_ARRAY (PSEE_CID_ROI_CTRL + 8)
+
+struct genx320_roi {
+	u32 x;
+	u32 y;
+	u32 width;
+	u32 height;
+};
+
+struct genx320_roi_set {
+	u32 n;
+	struct genx320_roi rois[GENX320_MAX_ROI_WINDOWS];
+};
+
+struct genx320_pixel_row {
+	bool dirty;
+	u32 vectors[GENX320_PIXEL_ARRAY_WORDS];
+};
+
+struct genx320_pixel_grid {
+	u32 width;
+	u32 height;
+	struct genx320_pixel_row rows[GENX320_PIXEL_ARRAY_HEIGHT];
+};
+
+struct genx320 {
+	struct i2c_client *i2c_client;
+	struct v4l2_subdev *subdev;
+	struct v4l2_ctrl *roi_set_ctrl;
+	struct v4l2_ctrl *roi_roni_ctrl;
+	struct v4l2_ctrl *roi_pixel_ctrl;
+	struct v4l2_ctrl *erc_enable_ctrl;
+	struct v4l2_ctrl *erc_rate_ctrl;
+	struct v4l2_ctrl *bias_ctrls[GENX320_NUM_BIAS_CTRLS];
+	struct camera_common_sensor_ops common_ops;
+	struct camera_common_frmfmt frmfmt[GENX320_NUM_FRMFMTS];
+	u32 rstn_delay_ms;
+	u32 transport_packet_size;
+	u32 transport_frame_size;
+	u32 transport_window_us;
+	u8 evt_format;
+	u8 transport_mode;
+	struct camera_common_data *s_data;
+	struct tegracam_device *tc_dev;
+	struct delayed_work status_work;
+	bool status_poll_active;
+};
+
+enum genx320_evt_format {
+	GENX320_EVT_FORMAT_EVT2 = 0,
+	GENX320_EVT_FORMAT_EVT21,
+	GENX320_EVT_FORMAT_EVT3,
+};
+
+enum genx320_transport_mode {
+	/* psee,transport-mode = "variable" */
+	GENX320_TRANSPORT_MODE_VARIABLE = 0,
+	/* psee,transport-mode = "fixed-frame-size" */
+	GENX320_TRANSPORT_MODE_FIXED_FRAME_SIZE,
+};
+
+enum genx320_transport_cfg_idx {
+	GENX320_TRANSPORT_CFG_CSI_CTRL = 0,
+	GENX320_TRANSPORT_CFG_FRAME_CTRL,
+	GENX320_TRANSPORT_CFG_FRAME_SIZE,
+	GENX320_TRANSPORT_CFG_EDF_TIMEOUT,
+};
+
+int genx320_apply_evt_format(struct genx320 *priv);
+int genx320_apply_transport_mode(struct genx320 *priv);
+int genx320_apply_roi_config(struct genx320 *priv,
+			     const struct genx320_roi_set *set, bool roni);
+int genx320_apply_pixel_array_config(struct genx320 *priv,
+				     const struct genx320_pixel_grid *grid);
+int genx320_set_erc_event_rate(struct genx320 *priv, s64 rate);
+int genx320_set_erc_enable(struct genx320 *priv, bool en);
+int genx320_apply_erc_controls(struct genx320 *priv);
+int genx320_write_bias_reg(struct genx320 *priv, u16 addr, u8 val);
+int genx320_apply_bias_controls(struct genx320 *priv);
+int genx320_register_v4l2_controls(struct genx320 *priv);
+extern struct tegracam_ctrl_ops genx320_ctrl_ops;
+
+#endif
diff --git a/nvidia-oot/drivers/media/i2c/genx320_ctrls.c b/nvidia-oot/drivers/media/i2c/genx320_ctrls.c
new file mode 100644
index 000000000..71a6ddf79
--- /dev/null
+++ b/nvidia-oot/drivers/media/i2c/genx320_ctrls.c
@@ -0,0 +1,654 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * GENX320 control handlers and registration.
+ */
+
+#include <linux/kernel.h>
+#include <linux/string.h>
+
+#include <media/tegra_v4l2_camera.h>
+
+#include "genx320.h"
+#include "genx320_regs.h"
+
+static const u32 ctrl_cid_list[] = {
+	TEGRA_CAMERA_CID_SENSOR_MODE_ID,
+};
+
+static const char *const genx320_evt_format_names[] = {
+	"EVT2",
+	"EVT21",
+	"EVT3",
+};
+
+#define GENX320_ERC_TD_EVENT_COUNT_DEFAULT 1000
+#define GENX320_ERC_MIN_EVENT_RATE 0
+#define GENX320_ERC_MAX_EVENT_RATE                    \
+	((GENX320_ERC_TD_EVENT_COUNT_MAX * 1000000) / \
+	 GENX320_ERC_REF_PERIOD_DEFAULT)
+#define GENX320_ERC_DEFAULT_EVENT_RATE                    \
+	((GENX320_ERC_TD_EVENT_COUNT_DEFAULT * 1000000) / \
+	 GENX320_ERC_REF_PERIOD_DEFAULT)
+
+struct genx320_bias_desc {
+	const char *name;
+	u16 addr;
+	u8 min;
+	u8 max;
+	u8 def;
+};
+
+static const struct genx320_bias_desc
+	genx320_bias_descs[GENX320_NUM_BIAS_CTRLS] = {
+		{
+			.name = "bias_fo",
+			.addr = GENX320_BIAS0_FO_ADDR,
+			.min = 19,
+			.max = 50,
+			.def = 34,
+		},
+		{
+			.name = "bias_hpf",
+			.addr = GENX320_BIAS0_HPF_ADDR,
+			.min = 0,
+			.max = 127,
+			.def = 40,
+		},
+		{
+			.name = "bias_diff_on",
+			.addr = GENX320_BIAS0_DIFF_ON_ADDR,
+			.min = 24,
+			.max = 78,
+			.def = 25,
+		},
+		{
+			.name = "bias_diff",
+			.addr = GENX320_BIAS0_DIFF_ADDR,
+			.min = 41,
+			.max = 51,
+			.def = 51,
+		},
+		{
+			.name = "bias_diff_off",
+			.addr = GENX320_BIAS0_DIFF_OFF_ADDR,
+			.min = 19,
+			.max = 127,
+			.def = 28,
+		},
+		{
+			.name = "bias_refr",
+			.addr = GENX320_BIAS0_REFR_ADDR,
+			.min = 0,
+			.max = 127,
+			.def = 10,
+		},
+	};
+
+static int genx320_bias_index_from_ctrl_id(u32 ctrl_id)
+{
+	if (ctrl_id < PSEE_CID_BIAS_CTRL ||
+	    ctrl_id >= PSEE_CID_BIAS_CTRL + GENX320_NUM_BIAS_CTRLS)
+		return -EINVAL;
+
+	return ctrl_id - PSEE_CID_BIAS_CTRL;
+}
+
+static int genx320_apply_bias_ctrl(struct genx320 *priv, u32 ctrl_id, s64 val)
+{
+	const struct genx320_bias_desc *desc;
+	int bias_idx;
+
+	if (!priv)
+		return -EINVAL;
+
+	bias_idx = genx320_bias_index_from_ctrl_id(ctrl_id);
+	if (bias_idx < 0)
+		return bias_idx;
+
+	desc = &genx320_bias_descs[bias_idx];
+
+	return genx320_write_bias_reg(priv, desc->addr, val);
+}
+
+static int genx320_set_erc(struct genx320 *priv, bool enable, s64 rate)
+{
+	int err;
+
+	if (enable) {
+		err = genx320_set_erc_event_rate(priv, rate);
+		if (err)
+			return err;
+	}
+
+	return genx320_set_erc_enable(priv, enable);
+}
+
+int genx320_apply_erc_controls(struct genx320 *priv)
+{
+	if (!priv || !priv->erc_enable_ctrl || !priv->erc_rate_ctrl)
+		return 0;
+
+	return genx320_set_erc(priv, !!priv->erc_enable_ctrl->val,
+			       *priv->erc_rate_ctrl->p_cur.p_s64);
+}
+
+int genx320_apply_bias_controls(struct genx320 *priv)
+{
+	u32 i;
+	int err;
+
+	for (i = 0; i < GENX320_NUM_BIAS_CTRLS; i++) {
+		if (!priv->bias_ctrls[i])
+			continue;
+
+		err = genx320_apply_bias_ctrl(priv, PSEE_CID_BIAS_CTRL + i,
+					      priv->bias_ctrls[i]->val);
+		if (err)
+			return err;
+	}
+
+	return 0;
+}
+
+static struct genx320 *genx320_priv_from_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct tegracam_ctrl_handler *hdl = container_of(
+		ctrl->handler, struct tegracam_ctrl_handler, ctrl_handler);
+
+	return tegracam_get_privdata(hdl->tc_dev);
+}
+
+static int genx320_evt_format_s_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct genx320 *priv = genx320_priv_from_ctrl(ctrl);
+
+	if (!priv || !priv->tc_dev)
+		return -EINVAL;
+
+	if (priv->tc_dev->is_streaming)
+		return -EBUSY;
+
+	switch (ctrl->val) {
+	case GENX320_EVT_FORMAT_EVT2:
+	case GENX320_EVT_FORMAT_EVT21:
+	case GENX320_EVT_FORMAT_EVT3:
+		priv->evt_format = ctrl->val;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	if (priv->s_data && priv->s_data->power &&
+	    priv->s_data->power->state == SWITCH_ON)
+		return genx320_apply_evt_format(priv);
+
+	return 0;
+}
+
+static const struct v4l2_ctrl_ops genx320_evt_format_ctrl_ops = {
+	.s_ctrl = genx320_evt_format_s_ctrl,
+};
+
+static int genx320_erc_ctrl_s_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct genx320 *priv = genx320_priv_from_ctrl(ctrl);
+
+	if (!priv || ctrl->id != PSEE_CID_ERC_ENABLE)
+		return -EINVAL;
+
+	return genx320_set_erc(priv, !!ctrl->val,
+			       *ctrl->cluster[1]->p_new.p_s64);
+}
+
+static const struct v4l2_ctrl_ops genx320_erc_ctrl_ops = {
+	.s_ctrl = genx320_erc_ctrl_s_ctrl,
+};
+
+static int genx320_bias_ctrl_s_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct genx320 *priv = genx320_priv_from_ctrl(ctrl);
+
+	if (!priv)
+		return -EINVAL;
+
+	return genx320_apply_bias_ctrl(priv, ctrl->id, ctrl->val);
+}
+
+static const struct v4l2_ctrl_ops genx320_bias_ctrl_ops = {
+	.s_ctrl = genx320_bias_ctrl_s_ctrl,
+};
+
+static bool genx320_roi_set_equal(const struct v4l2_ctrl *ctrl, u32 idx,
+				  union v4l2_ctrl_ptr ptr1,
+				  union v4l2_ctrl_ptr ptr2)
+{
+	const struct genx320_roi_set *set1 = ptr1.p_const;
+	const struct genx320_roi_set *set2 = ptr2.p_const;
+	u32 i;
+
+	(void)ctrl;
+
+	/* roi_set is a single compound payload, not an array of compounds. */
+	if (idx)
+		return true;
+
+	if (set1->n != set2->n)
+		return false;
+
+	for (i = 0; i < set1->n; i++) {
+		if (set1->rois[i].x != set2->rois[i].x ||
+		    set1->rois[i].y != set2->rois[i].y ||
+		    set1->rois[i].width != set2->rois[i].width ||
+		    set1->rois[i].height != set2->rois[i].height)
+			return false;
+	}
+
+	return true;
+}
+
+static void genx320_roi_set_init(const struct v4l2_ctrl *ctrl, u32 idx,
+				 union v4l2_ctrl_ptr ptr)
+{
+	struct genx320_roi_set *set = ptr.p;
+
+	(void)ctrl;
+
+	if (idx)
+		return;
+
+	memset(set, 0, sizeof(*set));
+}
+
+static void genx320_roi_set_log(const struct v4l2_ctrl *ctrl)
+{
+	const struct genx320_roi_set *set = ctrl->p_cur.p_const;
+	char buf[GENX320_MAX_ROI_WINDOWS * 32 + 16];
+	size_t len;
+	u32 i;
+
+	len = scnprintf(buf, sizeof(buf), "n=%u", set->n);
+
+	for (i = 0; i < min_t(u32, set->n, GENX320_MAX_ROI_WINDOWS); i++) {
+		const struct genx320_roi *roi = &set->rois[i];
+
+		len += scnprintf(buf + len, sizeof(buf) - len,
+				 " [%u]={x=%u,y=%u,w=%u,h=%u}", i, roi->x,
+				 roi->y, roi->width, roi->height);
+	}
+
+	pr_info("%s: %s\n", ctrl->name, buf);
+}
+
+static int genx320_validate_roi_rect(const struct genx320_roi *roi)
+{
+	if (!roi->width || !roi->height)
+		return -ERANGE;
+
+	if (roi->x >= GENX320_PIXEL_ARRAY_WIDTH ||
+	    roi->y >= GENX320_PIXEL_ARRAY_HEIGHT)
+		return -ERANGE;
+
+	if (roi->width > GENX320_PIXEL_ARRAY_WIDTH - roi->x ||
+	    roi->height > GENX320_PIXEL_ARRAY_HEIGHT - roi->y)
+		return -ERANGE;
+
+	return 0;
+}
+
+static int genx320_roi_set_validate(const struct v4l2_ctrl *ctrl, u32 idx,
+				    union v4l2_ctrl_ptr ptr)
+{
+	const struct genx320_roi_set *set = ptr.p_const;
+	u32 i;
+
+	(void)ctrl;
+
+	if (idx)
+		return 0;
+
+	if (set->n > GENX320_MAX_ROI_WINDOWS)
+		return -ERANGE;
+
+	for (i = 0; i < set->n; i++) {
+		int err = genx320_validate_roi_rect(&set->rois[i]);
+
+		if (err)
+			return err;
+	}
+
+	return 0;
+}
+
+static const struct v4l2_ctrl_type_ops genx320_roi_set_type_ops = {
+	.equal = genx320_roi_set_equal,
+	.init = genx320_roi_set_init,
+	.log = genx320_roi_set_log,
+	.validate = genx320_roi_set_validate,
+};
+
+static bool genx320_pixel_grid_equal(const struct v4l2_ctrl *ctrl, u32 idx,
+				     union v4l2_ctrl_ptr ptr1,
+				     union v4l2_ctrl_ptr ptr2)
+{
+	const struct genx320_pixel_grid *grid1 = ptr1.p_const;
+	const struct genx320_pixel_grid *grid2 = ptr2.p_const;
+	u32 y;
+	u32 x;
+
+	(void)ctrl;
+
+	if (idx)
+		return true;
+
+	if (grid1->width != grid2->width || grid1->height != grid2->height)
+		return false;
+
+	for (y = 0; y < grid1->height; y++) {
+		for (x = 0; x < GENX320_PIXEL_ARRAY_WORDS; x++) {
+			if (grid1->rows[y].vectors[x] !=
+			    grid2->rows[y].vectors[x])
+				return false;
+		}
+	}
+
+	return true;
+}
+
+static void genx320_pixel_grid_init(const struct v4l2_ctrl *ctrl, u32 idx,
+				    union v4l2_ctrl_ptr ptr)
+{
+	struct genx320_pixel_grid *grid = ptr.p;
+	u32 y;
+
+	(void)ctrl;
+
+	if (idx)
+		return;
+
+	memset(grid, 0, sizeof(*grid));
+	grid->width = GENX320_PIXEL_ARRAY_WIDTH;
+	grid->height = GENX320_PIXEL_ARRAY_HEIGHT;
+
+	for (y = 0; y < grid->height; y++)
+		memset(grid->rows[y].vectors, 0xFF,
+		       sizeof(grid->rows[y].vectors));
+}
+
+static void genx320_pixel_grid_log(const struct v4l2_ctrl *ctrl)
+{
+	const struct genx320_pixel_grid *grid = ctrl->p_cur.p_const;
+
+	pr_info("%s: width=%u height=%u\n", ctrl->name, grid->width,
+		grid->height);
+}
+
+static int genx320_pixel_grid_validate(const struct v4l2_ctrl *ctrl, u32 idx,
+				       union v4l2_ctrl_ptr ptr)
+{
+	const struct genx320_pixel_grid *grid = ptr.p_const;
+
+	(void)ctrl;
+
+	if (idx)
+		return 0;
+
+	if (grid->width != GENX320_PIXEL_ARRAY_WIDTH ||
+	    grid->height != GENX320_PIXEL_ARRAY_HEIGHT)
+		return -ERANGE;
+
+	return 0;
+}
+
+static const struct v4l2_ctrl_type_ops genx320_pixel_grid_type_ops = {
+	.equal = genx320_pixel_grid_equal,
+	.init = genx320_pixel_grid_init,
+	.log = genx320_pixel_grid_log,
+	.validate = genx320_pixel_grid_validate,
+};
+
+static int genx320_roi_ctrl_try_ctrl(struct v4l2_ctrl *ctrl)
+{
+	if (ctrl->id == PSEE_CID_ROI_WINDOW_SET)
+		return genx320_roi_set_validate(ctrl, 0, ctrl->p_new);
+
+	if (ctrl->id == GENX320_CID_ROI_PIXEL_ARRAY)
+		return genx320_pixel_grid_validate(ctrl, 0, ctrl->p_new);
+
+	if (ctrl->id == PSEE_CID_ROI_RONI && (ctrl->val < 0 || ctrl->val > 1))
+		return -ERANGE;
+
+	return 0;
+}
+
+static int genx320_roi_ctrl_s_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct genx320 *priv = genx320_priv_from_ctrl(ctrl);
+	struct genx320_roi_set *roi_set;
+	struct genx320_pixel_grid *pixel_grid;
+
+	if (!priv)
+		return -EINVAL;
+
+	switch (ctrl->id) {
+	case PSEE_CID_ROI_WINDOW_SET:
+		return genx320_apply_roi_config(
+			priv, ctrl->p_new.p,
+			priv->roi_roni_ctrl ? !!priv->roi_roni_ctrl->val :
+						    false);
+	case GENX320_CID_ROI_PIXEL_ARRAY:
+		return genx320_apply_pixel_array_config(priv, ctrl->p_new.p);
+	case GENX320_CID_ROI_PIXEL_RESET:
+		if (!priv->roi_pixel_ctrl)
+			return -EINVAL;
+
+		pixel_grid = priv->roi_pixel_ctrl->p_cur.p;
+		if (!pixel_grid)
+			return -EINVAL;
+
+		genx320_pixel_grid_init(priv->roi_pixel_ctrl, 0,
+					priv->roi_pixel_ctrl->p_cur);
+		if (priv->roi_pixel_ctrl->p_new.p)
+			genx320_pixel_grid_init(priv->roi_pixel_ctrl, 0,
+						priv->roi_pixel_ctrl->p_new);
+
+		return genx320_apply_pixel_array_config(priv, pixel_grid);
+	case PSEE_CID_ROI_RONI:
+		if (!priv->roi_set_ctrl)
+			return -EINVAL;
+
+		roi_set = priv->roi_set_ctrl->p_cur.p;
+		if (!roi_set || !roi_set->n)
+			return 0;
+
+		return genx320_apply_roi_config(priv, roi_set, !!ctrl->val);
+	case PSEE_CID_ROI_RESET:
+		if (!priv->roi_set_ctrl)
+			return -EINVAL;
+
+		roi_set = priv->roi_set_ctrl->p_cur.p;
+		if (!roi_set)
+			return -EINVAL;
+
+		roi_set->n = 0;
+
+		return genx320_apply_roi_config(priv, roi_set, false);
+	default:
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static const struct v4l2_ctrl_ops genx320_roi_ctrl_ops = {
+	.try_ctrl = genx320_roi_ctrl_try_ctrl,
+	.s_ctrl = genx320_roi_ctrl_s_ctrl,
+};
+
+static const struct v4l2_ctrl_config genx320_evt_format_ctrl_config = {
+	.id = GENX320_CID_EVT_FORMAT,
+	.name = "evt_format",
+	.type = V4L2_CTRL_TYPE_MENU,
+	.min = 0,
+	.max = ARRAY_SIZE(genx320_evt_format_names) - 1,
+	.def = GENX320_EVT_FORMAT_EVT21,
+	.qmenu = genx320_evt_format_names,
+	.ops = &genx320_evt_format_ctrl_ops,
+};
+
+static const struct v4l2_ctrl_config genx320_width_ctrl_config = {
+	.id = GENX320_CID_WIDTH,
+	.name = "width",
+	.type = V4L2_CTRL_TYPE_INTEGER,
+	.min = GENX320_PIXEL_ARRAY_WIDTH,
+	.max = GENX320_PIXEL_ARRAY_WIDTH,
+	.step = 1,
+	.def = GENX320_PIXEL_ARRAY_WIDTH,
+	.flags = V4L2_CTRL_FLAG_READ_ONLY,
+};
+
+static const struct v4l2_ctrl_config genx320_height_ctrl_config = {
+	.id = GENX320_CID_HEIGHT,
+	.name = "height",
+	.type = V4L2_CTRL_TYPE_INTEGER,
+	.min = GENX320_PIXEL_ARRAY_HEIGHT,
+	.max = GENX320_PIXEL_ARRAY_HEIGHT,
+	.step = 1,
+	.def = GENX320_PIXEL_ARRAY_HEIGHT,
+	.flags = V4L2_CTRL_FLAG_READ_ONLY,
+};
+
+static const struct v4l2_ctrl_config genx320_erc_enable_ctrl_config = {
+	.id = PSEE_CID_ERC_ENABLE,
+	.name = "erc_enable",
+	.type = V4L2_CTRL_TYPE_BOOLEAN,
+	.min = 0,
+	.max = 1,
+	.step = 1,
+	.def = 0,
+	.ops = &genx320_erc_ctrl_ops,
+};
+
+static const struct v4l2_ctrl_config genx320_erc_rate_ctrl_config = {
+	.id = PSEE_CID_ERC_RATE,
+	.name = "erc_rate",
+	.type = V4L2_CTRL_TYPE_INTEGER64,
+	.min = GENX320_ERC_MIN_EVENT_RATE,
+	.max = GENX320_ERC_MAX_EVENT_RATE,
+	.step = 1,
+	.def = GENX320_ERC_DEFAULT_EVENT_RATE,
+	.ops = &genx320_erc_ctrl_ops,
+};
+
+static const struct v4l2_ctrl_config genx320_roi_reset_ctrl_config = {
+	.id = PSEE_CID_ROI_RESET,
+	.name = "roi_reset",
+	.type = V4L2_CTRL_TYPE_BUTTON,
+	.min = 0,
+	.max = 0,
+	.step = 0,
+	.def = 0,
+	.ops = &genx320_roi_ctrl_ops,
+};
+
+static const struct v4l2_ctrl_config genx320_roi_roni_ctrl_config = {
+	.id = PSEE_CID_ROI_RONI,
+	.name = "roi_roni",
+	.type = V4L2_CTRL_TYPE_BOOLEAN,
+	.min = 0,
+	.max = 1,
+	.step = 1,
+	.def = 0,
+	.ops = &genx320_roi_ctrl_ops,
+};
+
+static const struct v4l2_ctrl_config genx320_roi_set_ctrl_config = {
+	.id = PSEE_CID_ROI_WINDOW_SET,
+	.name = "roi_set",
+	.type = PSEE_CMPTYPE_ROI,
+	.type_ops = &genx320_roi_set_type_ops,
+	.elem_size = sizeof(struct genx320_roi_set),
+	.ops = &genx320_roi_ctrl_ops,
+};
+
+static const struct v4l2_ctrl_config genx320_roi_pixel_reset_ctrl_config = {
+	.id = GENX320_CID_ROI_PIXEL_RESET,
+	.name = "pxl_reset",
+	.type = V4L2_CTRL_TYPE_BUTTON,
+	.min = 0,
+	.max = 0,
+	.step = 0,
+	.def = 0,
+	.ops = &genx320_roi_ctrl_ops,
+};
+
+static const struct v4l2_ctrl_config genx320_roi_pixel_array_ctrl_config = {
+	.id = GENX320_CID_ROI_PIXEL_ARRAY,
+	.name = "pxl_set",
+	.type = PSEE_CMPTYPE_ROI_PIXEL,
+	.type_ops = &genx320_pixel_grid_type_ops,
+	.elem_size = sizeof(struct genx320_pixel_grid),
+	.ops = &genx320_roi_ctrl_ops,
+};
+
+int genx320_register_v4l2_controls(struct genx320 *priv)
+{
+	struct v4l2_ctrl_handler *hdl = priv->subdev->ctrl_handler;
+	u32 i;
+
+	if (!hdl)
+		return -EINVAL;
+
+	v4l2_ctrl_new_custom(hdl, &genx320_evt_format_ctrl_config, NULL);
+	v4l2_ctrl_new_custom(hdl, &genx320_width_ctrl_config, NULL);
+	v4l2_ctrl_new_custom(hdl, &genx320_height_ctrl_config, NULL);
+	priv->erc_enable_ctrl = v4l2_ctrl_new_custom(
+		hdl, &genx320_erc_enable_ctrl_config, NULL);
+	priv->erc_rate_ctrl =
+		v4l2_ctrl_new_custom(hdl, &genx320_erc_rate_ctrl_config, NULL);
+	v4l2_ctrl_new_custom(hdl, &genx320_roi_reset_ctrl_config, NULL);
+	priv->roi_roni_ctrl =
+		v4l2_ctrl_new_custom(hdl, &genx320_roi_roni_ctrl_config, NULL);
+	priv->roi_set_ctrl =
+		v4l2_ctrl_new_custom(hdl, &genx320_roi_set_ctrl_config, NULL);
+	v4l2_ctrl_new_custom(hdl, &genx320_roi_pixel_reset_ctrl_config, NULL);
+	priv->roi_pixel_ctrl = v4l2_ctrl_new_custom(
+		hdl, &genx320_roi_pixel_array_ctrl_config, NULL);
+	for (i = 0; i < GENX320_NUM_BIAS_CTRLS; i++) {
+		struct v4l2_ctrl_config bias_ctrl_config = {
+			.id = PSEE_CID_BIAS_CTRL + i,
+			.name = genx320_bias_descs[i].name,
+			.type = V4L2_CTRL_TYPE_INTEGER,
+			.min = genx320_bias_descs[i].min,
+			.max = genx320_bias_descs[i].max,
+			.step = 1,
+			.def = genx320_bias_descs[i].def,
+			.ops = &genx320_bias_ctrl_ops,
+		};
+
+		priv->bias_ctrls[i] =
+			v4l2_ctrl_new_custom(hdl, &bias_ctrl_config, NULL);
+	}
+	if (priv->erc_enable_ctrl && priv->erc_rate_ctrl)
+		v4l2_ctrl_cluster(2, &priv->erc_enable_ctrl);
+
+	return hdl->error;
+}
+
+static int genx320_set_group_hold(struct tegracam_device *tc_dev, bool val)
+{
+	/*
+	 * tegracam requires a group-hold callback to validate ctrl ops,
+	 * but no sensor controls are registered, so this callback is not
+	 * exposed as a user-facing V4L2 control.
+	 */
+	if (!tc_dev || !tc_dev->priv)
+		return -EINVAL;
+
+	return 0;
+}
+
+struct tegracam_ctrl_ops genx320_ctrl_ops = {
+	.numctrls = ARRAY_SIZE(ctrl_cid_list),
+	.ctrl_cid_list = ctrl_cid_list,
+	.set_group_hold = genx320_set_group_hold,
+};
