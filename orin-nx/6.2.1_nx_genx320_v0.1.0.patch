+static void print_pixel_grid_summary(const struct genx320_pixel_grid *grid)
+{
+	uint32_t enabled = grid_count_enabled(grid);
+	uint32_t total = GENX320_PIXEL_ARRAY_WIDTH * GENX320_PIXEL_ARRAY_HEIGHT;
+
+	printf("pxl_set: width=%" PRIu32 " height=%" PRIu32 " enabled=%" PRIu32
+	       " disabled=%" PRIu32 "\n",
+	       grid->width, grid->height, enabled, total - enabled);
