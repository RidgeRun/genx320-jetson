+static int set_erc(int fd, bool enable, int64_t rate)
+{
+	struct v4l2_ext_controls ctrls;
+	struct v4l2_ext_control control[2];
+
+	memset(&ctrls, 0, sizeof(ctrls));
+	memset(control, 0, sizeof(control));
+
+	control[0].id = PSEE_CID_ERC_ENABLE;
+	control[0].value = enable ? 1 : 0;
+	control[1].id = PSEE_CID_ERC_RATE;
+	control[1].value64 = rate;
+
+	ctrls.which = V4L2_CTRL_ID2WHICH(PSEE_CID_ERC_ENABLE);
+	ctrls.count = ARRAY_SIZE(control);
+	ctrls.controls = control;
+
+	if (xioctl(fd, VIDIOC_S_EXT_CTRLS, &ctrls) == -1)
+		return -errno;
+
+	return 0;
+}
+
+static int get_erc(int fd, int32_t *enable, int64_t *rate)
+{
+	struct v4l2_ext_controls ctrls;
+	struct v4l2_ext_control control[2];
+
+	memset(&ctrls, 0, sizeof(ctrls));
+	memset(control, 0, sizeof(control));
+
+	control[0].id = PSEE_CID_ERC_ENABLE;
+	control[1].id = PSEE_CID_ERC_RATE;
+
+	ctrls.which = V4L2_CTRL_ID2WHICH(PSEE_CID_ERC_ENABLE);
+	ctrls.count = ARRAY_SIZE(control);
+	ctrls.controls = control;
+
+	if (xioctl(fd, VIDIOC_G_EXT_CTRLS, &ctrls) == -1)
+		return -errno;
+
+	*enable = control[0].value;
+	*rate = control[1].value64;
+	return 0;
+}
+
+static void print_scalar_value(int fd, const struct v4l2_query_ext_ctrl *query,
+			       const struct v4l2_ext_control *ctrl)
+{
+	char menu_name[32];
+
+	switch (query->type) {
+	case V4L2_CTRL_TYPE_INTEGER:
+	case V4L2_CTRL_TYPE_BOOLEAN:
+	case V4L2_CTRL_TYPE_MENU:
+	case V4L2_CTRL_TYPE_BUTTON:
+		printf("value=%d", ctrl->value);
+		if (query->id == GENX320_CID_EVT_FORMAT)
+			printf(" (%s)", evt_format_name(ctrl->value));
+		else if (query->type == V4L2_CTRL_TYPE_MENU &&
+			 query_menu_name(fd, query->id, ctrl->value, menu_name,
+					 sizeof(menu_name)) == 0)
+			printf(" (%s)", menu_name);
+		break;
+	case V4L2_CTRL_TYPE_INTEGER64:
+		printf("value=%" PRId64, (int64_t)ctrl->value64);
+		break;
+	default:
+		printf("value=<unsupported scalar type>");
+		break;
+	}
+	printf("\n");
+}
+
+static int cmd_list(int fd)
+{
+	struct v4l2_query_ext_ctrl query;
+	uint32_t next_id = V4L2_CTRL_FLAG_NEXT_CTRL;
+
+	printf("Known GENX320 controls:\n");
+	while (1) {
+		int ret;
+		struct v4l2_ext_control ctrl;
+
+		memset(&query, 0, sizeof(query));
+		query.id = next_id;
+
+		if (xioctl(fd, VIDIOC_QUERY_EXT_CTRL, &query) == -1) {
+			if (errno == EINVAL)
+				break;
+			return -errno;
+		}
+
+		printf("  %s (0x%08x): type=%s flags=", query.name, query.id,
+		       ctrl_type_name(query.type));
+		print_control_flags(query.flags);
+		printf("\n");
+
+		if (query.type == V4L2_CTRL_TYPE_CTRL_CLASS) {
+			next_id = query.id | V4L2_CTRL_FLAG_NEXT_CTRL;
+			continue;
+		}
+
+		ret = single_get(fd, query.id, &query, &ctrl);
+		if (ret == 0) {
+			if (query.id == PSEE_CID_ROI_WINDOW_SET) {
+				print_roi_set(ctrl.ptr);
+			} else if (query.id == GENX320_CID_ROI_PIXEL_ARRAY) {
+				print_pixel_grid_summary(ctrl.ptr);
+			} else {
+				printf("    ");
+				print_scalar_value(fd, &query, &ctrl);
+			}
+			free_control_payload(&query, &ctrl);
+		}
+
+		next_id = query.id | V4L2_CTRL_FLAG_NEXT_CTRL;
+	}
+
+	printf("\nTool aliases:\n");
+	for (size_t i = 0; i < ARRAY_SIZE(known_controls); i++) {
+		printf("  %s -> 0x%08x (%s)\n", known_controls[i].name,
+		       known_controls[i].id, known_controls[i].note);
+	}
+
+	return 0;
+}
+
+static int query_known_control(int fd, const char *token,
+			       struct v4l2_query_ext_ctrl *query,
+			       const struct known_control **known)
+{
+	uint32_t id;
+	int ret;
+
+	*known = find_known_control(token);
+	if (*known)
+		id = (*known)->id;
+	else {
+		ret = parse_u32(token, &id);
+		if (ret)
+			return ret;
+	}
+
+	return query_control(fd, id, query);
+}
+
+static int cmd_get(int fd, const char *token)
+{
+	const struct known_control *known = NULL;
+	struct v4l2_query_ext_ctrl query;
+	struct v4l2_ext_control ctrl;
+	int ret;
+
+	ret = query_known_control(fd, token, &query, &known);
+	if (ret)
+		return ret;
+
+	if (query.id == PSEE_CID_ERC_ENABLE || query.id == PSEE_CID_ERC_RATE) {
+		int32_t enable;
+		int64_t rate;
+
+		ret = get_erc(fd, &enable, &rate);
+		if (ret)
+			return ret;
+
+		printf("erc_enable=%d\n", enable);
+		printf("erc_rate=%" PRId64 "\n", rate);
+		return 0;
+	}
+
+	ret = single_get(fd, query.id, &query, &ctrl);
+	if (ret)
+		return ret;
+
+	if (query.id == PSEE_CID_ROI_WINDOW_SET)
+		print_roi_set(ctrl.ptr);
+	else if (query.id == GENX320_CID_ROI_PIXEL_ARRAY)
+		print_pixel_grid_summary(ctrl.ptr);
+	else
+		print_scalar_value(fd, &query, &ctrl);
+
+	free_control_payload(&query, &ctrl);
+	(void)known;
+	return 0;
+}
+
+static int cmd_info(int fd, const char *token)
+{
+	const struct known_control *known = NULL;
+	struct v4l2_query_ext_ctrl query;
+	int ret;
+
+	ret = query_known_control(fd, token, &query, &known);
+	if (ret)
+		return ret;
+
+	printf("name=%s\n", query.name);
+	printf("id=0x%08x\n", query.id);
+	printf("type=%s\n", ctrl_type_name(query.type));
+	printf("min=%" PRId64 "\n", (int64_t)query.minimum);
+	printf("max=%" PRId64 "\n", (int64_t)query.maximum);
+	printf("step=%" PRIu64 "\n", (uint64_t)query.step);
+	printf("default=%" PRId64 "\n", (int64_t)query.default_value);
+	printf("elem_size=%u\n", query.elem_size);
+	printf("elems=%u\n", query.elems);
+	printf("flags=");
+	print_control_flags(query.flags);
+	printf("\n");
+	if (known && known->note)
+		printf("note=%s\n", known->note);
+
+	return 0;
+}
+
+static int cmd_set_scalar(int fd, const char *token, const char *value_text)
+{
+	const struct known_control *known = NULL;
+	struct v4l2_query_ext_ctrl query;
+	struct v4l2_ext_control ctrl;
+	int ret;
+	int64_t value64;
+	int32_t value32;
+	bool bool_value;
+
+	ret = query_known_control(fd, token, &query, &known);
+	if (ret)
+		return ret;
+
+	if (query.id == PSEE_CID_ERC_ENABLE || query.id == PSEE_CID_ERC_RATE) {
+		fprintf(stderr,
+			"Use `erc <enable> <rate>` so both ERC controls are set together.\n");
+		return -EINVAL;
+	}
+
+	if (query.flags & V4L2_CTRL_FLAG_READ_ONLY) {
+		fprintf(stderr, "%s is read-only.\n", query.name);
+		return -EPERM;
+	}
+
+	memset(&ctrl, 0, sizeof(ctrl));
+	ctrl.id = query.id;
+
+	switch (query.type) {
+	case V4L2_CTRL_TYPE_BOOLEAN:
+		ret = parse_bool_value(value_text, &bool_value);
+		if (ret)
+			return ret;
+		ctrl.value = bool_value ? 1 : 0;
+		break;
+	case V4L2_CTRL_TYPE_MENU:
+		if (query.id == GENX320_CID_EVT_FORMAT) {
+			ret = parse_evt_format(value_text, &value32);
+			if (ret)
+				return ret;
+			ctrl.value = value32;
+			break;
+		}
+		ret = parse_s64(value_text, &value64);
+		if (ret)
+			return ret;
+		ctrl.value = (int32_t)value64;
+		break;
+	case V4L2_CTRL_TYPE_INTEGER:
+	case V4L2_CTRL_TYPE_BUTTON:
+		ret = parse_s64(value_text, &value64);
+		if (ret)
+			return ret;
+		ctrl.value = (int32_t)value64;
+		break;
+	case V4L2_CTRL_TYPE_INTEGER64:
+		ret = parse_s64(value_text, &value64);
+		if (ret)
+			return ret;
+		ctrl.value64 = value64;
+		break;
+	default:
+		fprintf(stderr, "Unsupported type for generic set: %s\n",
+			ctrl_type_name(query.type));
+		return -EINVAL;
+	}
+
+	ret = single_set(fd, query.id, &ctrl);
+	if (ret)
+		return ret;
+
+	printf("%s updated.\n", query.name);
+	(void)known;
+	return 0;
+}
+
+static int cmd_bias_restore(int fd)
+{
+	size_t i;
+
+	for (i = 0; i < ARRAY_SIZE(known_controls); i++) {
+		const struct known_control *known = &known_controls[i];
+		struct v4l2_query_ext_ctrl query;
+		int ret;
+
+		if (!is_bias_control_id(known->id))
+			continue;
+
+		ret = query_control(fd, known->id, &query);
+		if (ret)
+			return ret;
+
+		ret = set_int32_control(fd, known->id,
+					(int32_t)query.default_value);
+		if (ret)
+			return ret;
+
+		printf("%s restored to %" PRId64 "\n", known->name,
+		       (int64_t)query.default_value);
+	}
+
+	return 0;
+}
+
+static int parse_roi_rect(const char *text, struct genx320_roi *roi)
+{
+	char *tmp;
+	char *cursor;
+	char *part;
+	uint32_t values[4];
+	size_t idx = 0;
+	int ret = 0;
+
+	tmp = strdup(text);
+	if (!tmp)
+		return -ENOMEM;
+
+	cursor = tmp;
+	while ((part = strsep(&cursor, ",")) != NULL) {
+		if (idx >= ARRAY_SIZE(values)) {
+			ret = -EINVAL;
+			goto out;
+		}
+		ret = parse_u32(part, &values[idx]);
+		if (ret)
+			goto out;
+		idx++;
+	}
+
+	if (idx != ARRAY_SIZE(values)) {
+		ret = -EINVAL;
+		goto out;
+	}
+
+	roi->x = values[0];
+	roi->y = values[1];
+	roi->width = values[2];
+	roi->height = values[3];
+
+out:
+	free(tmp);
+	return ret;
+}
+
+static int cmd_roi_set(int fd, int argc, char **argv)
+{
+	struct genx320_roi_set set;
+	int i;
+
+	memset(&set, 0, sizeof(set));
+
+	if (argc > (int)GENX320_MAX_ROI_WINDOWS) {
+		fprintf(stderr, "Maximum %u ROI windows are supported.\n",
+			GENX320_MAX_ROI_WINDOWS);
+		return -EINVAL;
+	}
+
+	for (i = 0; i < argc; i++) {
+		int ret = parse_roi_rect(argv[i], &set.rois[i]);
+
+		if (ret) {
+			fprintf(stderr,
+				"Invalid ROI `%s`, expected x,y,width,height.\n",
+				argv[i]);
+			return ret;
+		}
+		set.n++;
+	}
+
+	return set_roi_set(fd, &set);
+}
+
+static int cmd_pixel_set(int fd, uint32_t x, uint32_t y, bool enabled)
+{
+	struct genx320_pixel_grid grid;
+	int ret;
+
+	ret = get_pixel_grid(fd, &grid);
+	if (ret)
+		return ret;
+
+	ret = grid_set_pixel(&grid, x, y, enabled);
+	if (ret)
+		return ret;
+
+	return set_pixel_grid(fd, &grid);
+}
+
+static int cmd_pixel_rect(int fd, uint32_t x, uint32_t y, uint32_t width,
+			  uint32_t height, bool enabled)
+{
+	struct genx320_pixel_grid grid;
+	int ret;
+
+	ret = get_pixel_grid(fd, &grid);
+	if (ret)
+		return ret;
+
+	ret = grid_set_rect(&grid, x, y, width, height, enabled);
+	if (ret)
+		return ret;
+
+	return set_pixel_grid(fd, &grid);
+}
+
+static int cmd_pixel_all(int fd, bool enabled)
+{
+	struct genx320_pixel_grid grid;
+
+	grid_init_enabled(&grid, enabled);
+	return set_pixel_grid(fd, &grid);
+}
+
+static int open_device(const char *path)
+{
+	int fd = open(path, O_RDWR);
+
+	if (fd == -1)
+		fprintf(stderr, "Failed to open %s: %s\n", path,
+			strerror(errno));
+
+	return fd;
+}
+
+static void print_usage(const char *prog)
+{
+	printf("Usage: %s --device /dev/v4l-subdevX <command> [args]\n", prog);
+	printf("\n");
+	printf("Commands:\n");
+	printf("  list\n");
+	printf("  info <control>\n");
+	printf("  get <control>\n");
+	printf("  set <control> <value>\n");
+	printf("  bias-restore\n");
+	printf("  button <roi_reset|pxl_reset>\n");
+	printf("  erc <enable> <rate>\n");
+	printf("  roi-set <x,y,w,h> [x,y,w,h ...]\n");
+	printf("  pixel <x> <y> <0|1>\n");
+	printf("  pixel-rect <x> <y> <w> <h> <0|1>\n");
+	printf("  pixel-all <0|1>\n");
+	printf("\n");
+	printf("Examples:\n");
+	printf("  %s -d /dev/v4l-subdev1 list\n", prog);
+	printf("  %s -d /dev/v4l-subdev1 get evt_format\n", prog);
+	printf("  %s -d /dev/v4l-subdev1 set roi_roni 1\n", prog);
+	printf("  %s -d /dev/v4l-subdev1 erc 1 5000000\n", prog);
+	printf("  %s -d /dev/v4l-subdev1 bias-restore\n", prog);
+	printf("  %s -d /dev/v4l-subdev1 roi-set 0,0,64,64 128,128,32,32\n",
+	       prog);
+	printf("  %s -d /dev/v4l-subdev1 pixel 10 20 0\n", prog);
+}
+
+static void print_errno_message(const char *what, int err)
+{
+	fprintf(stderr, "%s failed: %s (%d)\n", what, strerror(-err), -err);
+}
+
+int main(int argc, char **argv)
+{
+	const char *device = NULL;
+	const char *command;
+	int fd;
+	int opt;
+	int ret = 0;
+
+	while ((opt = getopt_long(argc, argv, "d:h", long_options, NULL)) !=
+	       -1) {
+		switch (opt) {
+		case 'd':
+			device = optarg;
+			break;
+		case 'h':
+			print_usage(argv[0]);
+			return 0;
+		default:
+			print_usage(argv[0]);
+			return 1;
+		}
+	}
+
+	if (!device || optind >= argc) {
+		print_usage(argv[0]);
+		return 1;
+	}
+
+	fd = open_device(device);
+	if (fd == -1)
+		return 1;
+
+	command = argv[optind++];
+
+	if (strcmp(command, "list") == 0) {
+		ret = cmd_list(fd);
+	} else if (strcmp(command, "info") == 0) {
+		if (optind >= argc)
+			ret = -EINVAL;
+		else
+			ret = cmd_info(fd, argv[optind]);
+	} else if (strcmp(command, "get") == 0) {
+		if (optind >= argc)
+			ret = -EINVAL;
+		else
+			ret = cmd_get(fd, argv[optind]);
+	} else if (strcmp(command, "set") == 0) {
+		if (optind + 1 >= argc)
+			ret = -EINVAL;
+		else
+			ret = cmd_set_scalar(fd, argv[optind],
+					     argv[optind + 1]);
+	} else if (strcmp(command, "bias-restore") == 0) {
+		ret = cmd_bias_restore(fd);
+	} else if (strcmp(command, "button") == 0) {
+		const struct known_control *known;
+
+		if (optind >= argc) {
+			ret = -EINVAL;
+		} else {
+			known = find_known_control(argv[optind]);
+			if (!known || known->kind != CTRL_KIND_BUTTON) {
+				fprintf(stderr,
+					"button expects roi_reset or pxl_reset.\n");
+				ret = -EINVAL;
+			} else {
+				ret = click_button(fd, known->id);
+			}
+		}
+	} else if (strcmp(command, "erc") == 0) {
+		bool enable;
+		int64_t rate;
+
+		if (optind + 1 >= argc)
+			ret = -EINVAL;
+		else if (parse_bool_value(argv[optind], &enable) != 0)
+			ret = -EINVAL;
+		else if (parse_s64(argv[optind + 1], &rate) != 0)
+			ret = -EINVAL;
+		else
+			ret = set_erc(fd, enable, rate);
+	} else if (strcmp(command, "roi-set") == 0) {
+		if (optind >= argc)
+			ret = -EINVAL;
+		else
+			ret = cmd_roi_set(fd, argc - optind, &argv[optind]);
+	} else if (strcmp(command, "pixel") == 0) {
+		uint32_t x;
+		uint32_t y;
+		bool enabled;
+
+		if (optind + 2 >= argc) {
+			ret = -EINVAL;
+		} else if (parse_u32(argv[optind], &x) != 0 ||
+			   parse_u32(argv[optind + 1], &y) != 0 ||
+			   parse_bool_value(argv[optind + 2], &enabled) != 0) {
+			ret = -EINVAL;
+		} else {
+			ret = cmd_pixel_set(fd, x, y, enabled);
+		}
+	} else if (strcmp(command, "pixel-rect") == 0) {
+		uint32_t x;
+		uint32_t y;
+		uint32_t width;
+		uint32_t height;
+		bool enabled;
+
+		if (optind + 4 >= argc) {
+			ret = -EINVAL;
+		} else if (parse_u32(argv[optind], &x) != 0 ||
+			   parse_u32(argv[optind + 1], &y) != 0 ||
+			   parse_u32(argv[optind + 2], &width) != 0 ||
+			   parse_u32(argv[optind + 3], &height) != 0 ||
+			   parse_bool_value(argv[optind + 4], &enabled) != 0) {
+			ret = -EINVAL;
+		} else {
+			ret = cmd_pixel_rect(fd, x, y, width, height, enabled);
+		}
+	} else if (strcmp(command, "pixel-all") == 0) {
+		bool enabled;
+
+		if (optind >= argc)
+			ret = -EINVAL;
+		else if (parse_bool_value(argv[optind], &enabled) != 0)
+			ret = -EINVAL;
+		else
+			ret = cmd_pixel_all(fd, enabled);
+	} else {
+		fprintf(stderr, "Unknown command: %s\n", command);
+		ret = -EINVAL;
+	}
+
+	if (ret == -EINVAL)
+		print_usage(argv[0]);
+	else if (ret)
+		print_errno_message(command, ret);
+
+	close(fd);
+	return ret ? 1 : 0;
+}
