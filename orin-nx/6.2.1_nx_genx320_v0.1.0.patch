+
+	memset(&ctrl, 0, sizeof(ctrl));
+	ctrl.id = id;
+	ctrl.value = value;
+
+	return single_set(fd, id, &ctrl);
+}
+
+static bool control_has_payload(const struct v4l2_query_ext_ctrl *query)
+{
+	return (query->flags & V4L2_CTRL_FLAG_HAS_PAYLOAD) ||
+	       query->type >= V4L2_CTRL_COMPOUND_TYPES;
+}
+
+static void free_control_payload(const struct v4l2_query_ext_ctrl *query,
+				 struct v4l2_ext_control *ctrl)
+{
+	if (!control_has_payload(query))
+		return;
+
+	free(ctrl->ptr);
+	ctrl->ptr = NULL;
+	ctrl->size = 0;
+}
+
+static void print_control_flags(uint32_t flags)
+{
+	bool printed = false;
+
+	if (flags & V4L2_CTRL_FLAG_READ_ONLY) {
+		printf("read-only");
+		printed = true;
+	}
+	if (flags & V4L2_CTRL_FLAG_EXECUTE_ON_WRITE) {
+		printf("%sexec-on-write", printed ? ", " : "");
+		printed = true;
+	}
+	if (flags & V4L2_CTRL_FLAG_HAS_PAYLOAD) {
+		printf("%spayload", printed ? ", " : "");
+		printed = true;
+	}
+	if (flags & V4L2_CTRL_FLAG_VOLATILE) {
+		printf("%svolatile", printed ? ", " : "");
+		printed = true;
+	}
+	if (!printed)
+		printf("none");
+}
+
+static void grid_init_enabled(struct genx320_pixel_grid *grid, bool enabled)
+{
+	uint32_t y;
+	uint32_t x;
+	uint32_t fill = enabled ? UINT32_MAX : 0U;
+
+	memset(grid, 0, sizeof(*grid));
+	grid->width = GENX320_PIXEL_ARRAY_WIDTH;
+	grid->height = GENX320_PIXEL_ARRAY_HEIGHT;
+
+	for (y = 0; y < GENX320_PIXEL_ARRAY_HEIGHT; y++) {
+		for (x = 0; x < GENX320_PIXEL_ARRAY_WORDS; x++)
+			grid->rows[y].vectors[x] = fill;
+	}
+}
+
+static int grid_set_pixel(struct genx320_pixel_grid *grid, uint32_t x,
+			  uint32_t y, bool enabled)
+{
+	uint32_t word;
+	uint32_t bit;
+	uint32_t mask;
+
+	if (x >= GENX320_PIXEL_ARRAY_WIDTH || y >= GENX320_PIXEL_ARRAY_HEIGHT)
+		return -ERANGE;
+
+	word = x / 32U;
+	bit = x % 32U;
+	mask = 1U << bit;
+
+	if (enabled)
+		grid->rows[y].vectors[word] |= mask;
+	else
+		grid->rows[y].vectors[word] &= ~mask;
+
+	return 0;
+}
+
+static int grid_set_rect(struct genx320_pixel_grid *grid, uint32_t x,
+			 uint32_t y, uint32_t width, uint32_t height,
+			 bool enabled)
+{
+	uint32_t xi;
+	uint32_t yi;
+
+	if (!width || !height)
+		return -ERANGE;
+	if (x >= GENX320_PIXEL_ARRAY_WIDTH || y >= GENX320_PIXEL_ARRAY_HEIGHT)
+		return -ERANGE;
+	if (width > GENX320_PIXEL_ARRAY_WIDTH - x ||
+	    height > GENX320_PIXEL_ARRAY_HEIGHT - y)
+		return -ERANGE;
+
+	for (yi = y; yi < y + height; yi++) {
+		for (xi = x; xi < x + width; xi++)
+			grid_set_pixel(grid, xi, yi, enabled);
+	}
+
+	return 0;
+}
+
+static bool grid_get_pixel(const struct genx320_pixel_grid *grid, uint32_t x,
+			   uint32_t y)
+{
+	uint32_t word = x / 32U;
+	uint32_t bit = x % 32U;
+
+	return !!(grid->rows[y].vectors[word] & (1U << bit));
+}
+
+static uint32_t grid_count_enabled(const struct genx320_pixel_grid *grid)
+{
+	uint32_t x;
+	uint32_t y;
+	uint32_t count = 0;
+
+	for (y = 0; y < GENX320_PIXEL_ARRAY_HEIGHT; y++) {
+		for (x = 0; x < GENX320_PIXEL_ARRAY_WIDTH; x++) {
+			if (grid_get_pixel(grid, x, y))
+				count++;
+		}
+	}
+
+	return count;
+}
