+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Userspace test utility for the Orin GENX320 V4L2 controls.
+ */
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <getopt.h>
+#include <inttypes.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <strings.h>
+#include <sys/ioctl.h>
+#include <sys/types.h>
+#include <time.h>
+#include <unistd.h>
+#include <linux/videodev2.h>
+
+#define ARRAY_SIZE(a) (sizeof(a) / sizeof((a)[0]))
+
+#define GENX320_PIXEL_ARRAY_WIDTH 320U
+#define GENX320_PIXEL_ARRAY_HEIGHT 320U
+#define GENX320_PIXEL_ARRAY_WORDS (GENX320_PIXEL_ARRAY_WIDTH / 32U)
+#define GENX320_MAX_ROI_WINDOWS 18U
+
+#define PSEE_ERC_CLASS 0x1000
+#define PSEE_BIAS_CLASS 0x3000
+#define PSEE_ROI_CLASS 0x4000
+
+#define PSEE_CID_ERC_CTRL (V4L2_CID_USER_BASE | PSEE_ERC_CLASS)
+#define PSEE_CID_ERC_RATE (PSEE_CID_ERC_CTRL + 1)
+#define PSEE_CID_ERC_ENABLE (PSEE_CID_ERC_CTRL + 2)
+
+#define PSEE_CID_BIAS_CTRL (V4L2_CID_USER_BASE | PSEE_BIAS_CLASS)
+
+#define PSEE_CID_ROI_CTRL (V4L2_CID_USER_BASE | PSEE_ROI_CLASS)
+#define PSEE_CID_ROI_RESET (PSEE_CID_ROI_CTRL + 1)
+#define PSEE_CID_ROI_WINDOW_SET (PSEE_CID_ROI_CTRL + 4)
+#define PSEE_CID_ROI_RONI (PSEE_CID_ROI_CTRL + 6)
+#define GENX320_CID_ROI_PIXEL_RESET (PSEE_CID_ROI_CTRL + 7)
+#define GENX320_CID_ROI_PIXEL_ARRAY (PSEE_CID_ROI_CTRL + 8)
+
+#define GENX320_CID_EVT_FORMAT (V4L2_CID_USER_BASE + 0x2003)
+#define GENX320_CID_WIDTH (V4L2_CID_USER_BASE + 0x2004)
+#define GENX320_CID_HEIGHT (V4L2_CID_USER_BASE + 0x2005)
+
+enum genx320_evt_format {
+	GENX320_EVT_FORMAT_EVT2 = 0,
+	GENX320_EVT_FORMAT_EVT21 = 1,
+	GENX320_EVT_FORMAT_EVT3 = 2,
+};
+
+struct genx320_roi {
+	uint32_t x;
+	uint32_t y;
+	uint32_t width;
+	uint32_t height;
+};
+
+struct genx320_roi_set {
+	uint32_t n;
+	struct genx320_roi rois[GENX320_MAX_ROI_WINDOWS];
+};
+
+struct genx320_pixel_row {
+	bool dirty;
+	uint32_t vectors[GENX320_PIXEL_ARRAY_WORDS];
+};
+
+struct genx320_pixel_grid {
+	uint32_t width;
+	uint32_t height;
+	struct genx320_pixel_row rows[GENX320_PIXEL_ARRAY_HEIGHT];
+};
+
+enum control_kind {
+	CTRL_KIND_SCALAR,
+	CTRL_KIND_BUTTON,
+	CTRL_KIND_ROI_SET,
+	CTRL_KIND_PIXEL_GRID,
+	CTRL_KIND_ERC_PAIR,
+};
+
+struct known_control {
+	const char *name;
+	uint32_t id;
+	enum control_kind kind;
+	const char *note;
+};
+
+static const struct known_control known_controls[] = {
+	{ "evt_format", GENX320_CID_EVT_FORMAT, CTRL_KIND_SCALAR,
+	  "menu: evt2, evt21, evt3" },
+	{ "width", GENX320_CID_WIDTH, CTRL_KIND_SCALAR, "read-only" },
+	{ "height", GENX320_CID_HEIGHT, CTRL_KIND_SCALAR, "read-only" },
+	{ "erc_enable", PSEE_CID_ERC_ENABLE, CTRL_KIND_ERC_PAIR,
+	  "set together with erc_rate" },
+	{ "erc_rate", PSEE_CID_ERC_RATE, CTRL_KIND_ERC_PAIR,
+	  "set together with erc_enable" },
+	{ "roi_reset", PSEE_CID_ROI_RESET, CTRL_KIND_BUTTON,
+	  "button: clears ROI windows" },
+	{ "roi_roni", PSEE_CID_ROI_RONI, CTRL_KIND_SCALAR,
+	  "boolean: 0=ROI, 1=RONI" },
+	{ "roi_set", PSEE_CID_ROI_WINDOW_SET, CTRL_KIND_ROI_SET,
+	  "compound: x,y,w,h ..." },
+	{ "pxl_reset", GENX320_CID_ROI_PIXEL_RESET, CTRL_KIND_BUTTON,
+	  "button: enable all pixels" },
