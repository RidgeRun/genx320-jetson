+	return 0;
+}
+
+static int parse_u32(const char *text, uint32_t *value)
+{
+	char *end = NULL;
+	unsigned long parsed;
+
+	errno = 0;
+	parsed = strtoul(text, &end, 0);
+	if (errno || !end || *end != '\0' || parsed > UINT32_MAX)
+		return -EINVAL;
+
+	*value = (uint32_t)parsed;
+	return 0;
+}
+
+static int parse_s64(const char *text, int64_t *value)
+{
+	char *end = NULL;
+	long long parsed;
+
+	errno = 0;
+	parsed = strtoll(text, &end, 0);
+	if (errno || !end || *end != '\0')
+		return -EINVAL;
+
+	*value = (int64_t)parsed;
+	return 0;
+}
+
+static int parse_bool_value(const char *text, bool *value)
+{
+	if (strcmp(text, "1") == 0 || strcasecmp(text, "true") == 0 ||
+	    strcasecmp(text, "on") == 0 || strcasecmp(text, "enable") == 0 ||
+	    strcasecmp(text, "enabled") == 0) {
+		*value = true;
+		return 0;
+	}
+
+	if (strcmp(text, "0") == 0 || strcasecmp(text, "false") == 0 ||
+	    strcasecmp(text, "off") == 0 || strcasecmp(text, "disable") == 0 ||
+	    strcasecmp(text, "disabled") == 0) {
+		*value = false;
+		return 0;
+	}
+
+	return -EINVAL;
+}
+
+static int parse_evt_format(const char *text, int32_t *value)
+{
+	if (strcasecmp(text, "evt2") == 0) {
+		*value = GENX320_EVT_FORMAT_EVT2;
+		return 0;
+	}
+
+	if (strcasecmp(text, "evt21") == 0) {
+		*value = GENX320_EVT_FORMAT_EVT21;
+		return 0;
+	}
+
+	if (strcasecmp(text, "evt3") == 0) {
+		*value = GENX320_EVT_FORMAT_EVT3;
+		return 0;
+	}
+
+	return -EINVAL;
+}
+
+static const char *evt_format_name(int32_t value)
+{
+	switch (value) {
+	case GENX320_EVT_FORMAT_EVT2:
+		return "evt2";
+	case GENX320_EVT_FORMAT_EVT21:
+		return "evt21";
+	case GENX320_EVT_FORMAT_EVT3:
+		return "evt3";
+	default:
+		return "unknown";
+	}
+}
+
+static int single_get(int fd, uint32_t id, struct v4l2_query_ext_ctrl *query,
+		      struct v4l2_ext_control *ctrl)
+{
+	struct v4l2_ext_controls ctrls;
+
+	memset(&ctrls, 0, sizeof(ctrls));
+	memset(ctrl, 0, sizeof(*ctrl));
+	ctrl->id = id;
+
+	if ((query->flags & V4L2_CTRL_FLAG_HAS_PAYLOAD) ||
+	    query->type >= V4L2_CTRL_COMPOUND_TYPES) {
+		ctrl->size =
+			query->elem_size * (query->elems ? query->elems : 1U);
+		ctrl->ptr = calloc(1, ctrl->size);
+		if (!ctrl->ptr)
+			return -ENOMEM;
+	}
+
+	ctrls.which = V4L2_CTRL_ID2WHICH(id);
+	ctrls.count = 1;
+	ctrls.controls = ctrl;
+
+	if (xioctl(fd, VIDIOC_G_EXT_CTRLS, &ctrls) == -1) {
+		int err = -errno;
+
+		free(ctrl->ptr);
+		ctrl->ptr = NULL;
+		return err;
+	}
+
+	return 0;
+}
+
+static int single_set(int fd, uint32_t id, struct v4l2_ext_control *ctrl)
+{
+	struct v4l2_ext_controls ctrls;
+
+	memset(&ctrls, 0, sizeof(ctrls));
+	ctrls.which = V4L2_CTRL_ID2WHICH(id);
+	ctrls.count = 1;
+	ctrls.controls = ctrl;
+
+	if (xioctl(fd, VIDIOC_S_EXT_CTRLS, &ctrls) == -1)
+		return -errno;
+
+	return 0;
+}
