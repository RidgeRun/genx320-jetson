+// SPDX-License-Identifier: GPL-2.0-only
+// SPDX-FileCopyrightText: Copyright (c) 2026, RidgeRun,LLC. All rights reserved.
+
+#include "tegra234-camera-genx320.dtsi"
+#include <dt-bindings/clock/tegra234-clock.h>
+#include <dt-bindings/gpio/tegra234-gpio.h>
+
+/*
+ * This file can be included directly in your main device tree
+ * when no dynamic DTBO overlay is required.
+ */
+#define CAM0_PWDN     TEGRA234_MAIN_GPIO(H, 6)
+#define CAM_I2C_MUX   TEGRA234_AON_GPIO(CC, 3)
+
+/* camera control gpio definitions */
+
+/ {
+	fragment-camera-genx320@0 {
+		target-path = "/bus@0";
+		__overlay__ {
+			gpio@2200000 {
+				camera-control-output-low {
+					gpio-hog;
+					output-low;
+					gpios = <CAM0_PWDN 0>;
+					label = "cam0-pwdn";
+				};
+			};
+
+			cam_i2cmux {
+				status = "okay";
+				compatible = "i2c-mux-gpio";
+				#address-cells = <1>;
+				#size-cells = <0>;
+				mux-gpios = <&gpio_aon CAM_I2C_MUX GPIO_ACTIVE_HIGH>;
+				i2c-parent = <&cam_i2c>;
+				i2c@0 {
+					status = "okay";
+					reg = <0>;
+					#address-cells = <1>;
+					#size-cells = <0>;
+					genx320_a@3c {
+						reset-gpios = <&gpio CAM0_PWDN GPIO_ACTIVE_HIGH>;
+						/* CCAM5 handling RSTn needs 285 = 55 + 230  (~200 ms delay for reset -> RSTn)*/
+						rstn-delay-ms = <385>;
+						reg = <0x3c>;
+					};
+				};
+			};
+		};
+	};
+};
